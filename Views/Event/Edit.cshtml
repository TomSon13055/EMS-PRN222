@model EventManagement.ViewModels.EditEventViewModel
@{
    ViewData["Title"] = $"Edit · {Model.Title}";
    Layout = "_Layout";
}

<nav aria-label="Breadcrumb" class="breadcrumb" style="margin-bottom: var(--space-6);">
    <a href="@Url.Action("MyEvents", "Host")">My events</a>
    <i class="bi bi-chevron-right breadcrumb__separator" aria-hidden="true"></i>
    <span class="breadcrumb__current">Edit event</span>
</nav>

<header class="page-header page-header--compact" style="border-bottom: 0;">
    <div class="page-header__titles">
        <span class="page-header__eyebrow">Editing</span>
        <h1 class="page-header__title">@Model.Title</h1>
        <p class="page-header__subtitle">Update the details of your event. Changes will be visible to customers immediately after saving.</p>
    </div>
    <div class="page-header__actions">
        <a class="btn btn--ghost" href="@Url.Action("MyEvents", "Host")">
            <i class="bi bi-arrow-left" aria-hidden="true"></i>
            <span>Back</span>
        </a>
        <a class="btn btn--secondary" href="@Url.Action("Details", "Event", new { id = Model.EventId })">
            <i class="bi bi-eye" aria-hidden="true"></i>
            <span>Preview public page</span>
        </a>
    </div>
</header>

<form asp-action="Edit" method="post" novalidate>
    <input type="hidden" asp-for="EventId" />
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>

    <section class="form-section">
        <span class="form-section__step">01 · Event identity</span>
        <h2 class="form-section__title">The basics</h2>
        <p class="form-section__subtitle">A clear title and description help customers decide faster.</p>

        <div class="form-field">
            <label asp-for="Title" class="form-label">
                <span>Title</span>
                <span class="form-label__required" aria-hidden="true">*</span>
            </label>
            <input asp-for="Title" class="form-control" maxlength="150" />
            <span asp-validation-for="Title" class="field-validation-error"></span>
        </div>

        <div class="form-field">
            <label asp-for="Description" class="form-label">
                <span>Description</span>
                <span class="form-label__required" aria-hidden="true">*</span>
            </label>
            <textarea asp-for="Description" class="form-control form-control--textarea" rows="6"></textarea>
            <span asp-validation-for="Description" class="field-validation-error"></span>
        </div>

        <div class="form-field">
            <label asp-for="EventCategoryId" class="form-label">
                <span>Category</span>
                <span class="form-label__required" aria-hidden="true">*</span>
            </label>
            <select asp-for="EventCategoryId" class="form-select">
                @if (Model.Categories != null)
                {
                    foreach (var c in Model.Categories.Where(x => !string.IsNullOrEmpty(x.Value)))
                    {
                        <option value="@c.Value" selected="@(c.Value == Model.EventCategoryId.ToString())">@c.Text</option>
                    }
                }
            </select>
            <span asp-validation-for="EventCategoryId" class="field-validation-error"></span>
        </div>
    </section>

    <section class="form-section">
        <span class="form-section__step">02 · Schedule</span>
        <h2 class="form-section__title">When &amp; where</h2>
        <p class="form-section__subtitle">Pick the venue and the start/end times for the event.</p>

        <div class="form-field">
            <label asp-for="EventLocationId" class="form-label">
                <span>Location</span>
                <span class="form-label__required" aria-hidden="true">*</span>
            </label>
            <select asp-for="EventLocationId" class="form-select">
                @if (Model.Locations != null)
                {
                    foreach (var l in Model.Locations.Where(x => !string.IsNullOrEmpty(x.Value)))
                    {
                        <option value="@l.Value" selected="@(l.Value == Model.EventLocationId.ToString())">@l.Text</option>
                    }
                }
            </select>
            <span asp-validation-for="EventLocationId" class="field-validation-error"></span>
        </div>

        <div class="form-grid-2">
            <div class="form-field" style="margin: 0;">
                <label asp-for="StartTime" class="form-label">
                    <span>Start time</span>
                    <span class="form-label__required" aria-hidden="true">*</span>
                </label>
                <input asp-for="StartTime" type="datetime-local" class="form-control"
                       value="@(Model.StartTime == default ? string.Empty : Model.StartTime.ToString("yyyy-MM-ddTHH:mm"))" />
                <span asp-validation-for="StartTime" class="field-validation-error"></span>
            </div>
            <div class="form-field" style="margin: 0;">
                <label asp-for="EndTime" class="form-label">
                    <span>End time</span>
                    <span class="form-label__required" aria-hidden="true">*</span>
                </label>
                <input asp-for="EndTime" type="datetime-local" class="form-control"
                       value="@(Model.EndTime == default ? string.Empty : Model.EndTime.ToString("yyyy-MM-ddTHH:mm"))" />
                <span asp-validation-for="EndTime" class="field-validation-error"></span>
            </div>
        </div>
    </section>

    <section class="form-section">
        <span class="form-section__step">03 · Visual</span>
        <h2 class="form-section__title">Cover image</h2>
        <p class="form-section__subtitle">A great cover image is the difference between scrolling past and grabbing a ticket.</p>

        <div class="event-form-image">
            <div class="form-field" style="margin: 0;">
                <label asp-for="ImageUrl" class="form-label">Image URL</label>
                <input asp-for="ImageUrl" class="form-control" data-image-preview-input="#imagePreview" />
                <span asp-validation-for="ImageUrl" class="field-validation-error"></span>
            </div>
            <div class="image-preview" id="imagePreview">
                @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                {
                    <div class="image-preview__thumb"><img src="@Model.ImageUrl" alt="Event cover preview" /></div>
                    <span class="image-preview__caption">Current image</span>
                }
                else
                {
                    <span class="image-preview__caption">Paste an image URL above to preview it here.</span>
                }
            </div>
        </div>
    </section>

    <section class="form-section">
        <span class="form-section__step">04 · Publishing</span>
        <h2 class="form-section__title">Visibility</h2>
        <div class="form-field" style="max-width: 320px;">
            <label asp-for="Status" class="form-label">Status</label>
            <select asp-for="Status" class="form-select">
                @if (Model.Statuses != null)
                {
                    foreach (var s in Model.Statuses)
                    {
                        <option value="@s.Value" selected="@(s.Value == Model.Status)">@s.Text</option>
                    }
                }
            </select>
            <span class="field-hint">Draft keeps the event hidden from customers.</span>
            <span asp-validation-for="Status" class="field-validation-error"></span>
        </div>
    </section>

    @if (Model.TicketTypes != null && Model.TicketTypes.Any())
    {
        <section class="form-section">
            <span class="form-section__step">05 · Tickets</span>
            <h2 class="form-section__title">Existing ticket types</h2>
            <p class="form-section__subtitle">These tickets are already on sale. Manage their details from the ticket types page.</p>
            <div class="ticket-type-list">
                @foreach (var t in Model.TicketTypes)
                {
                    <article class="ticket-type-row">
                        <div>
                            <h4 class="ticket-type-row__name">@t.TypeName</h4>
                            <div class="ticket-type-row__meta">
                                <span><strong>@t.Quantity</strong> tickets</span>
                                <span class="muted">@t.SaleStart.ToString("dd MMM") – @t.SaleEnd.ToString("dd MMM")</span>
                                <partial name="_StatusBadge" model="t.Status" />
                            </div>
                        </div>
                        <div></div>
                        <div class="ticket-type-row__price">
                            @if (t.Price <= 0) { <span style="color: var(--success);">Free</span> }
                            else { @t.Price.ToString("N0")<span style="font-size: 0.55em; margin-left: 2px;">đ</span> }
                        </div>
                    </article>
                }
            </div>
        </section>
    }
    else
    {
        <section class="form-section">
            <span class="form-section__step">05 · Tickets</span>
            <h2 class="form-section__title">Ticket types</h2>
            @await Html.PartialAsync("_EmptyState", new EventManagement.ViewModels.EmptyStateViewModel
            {
                Title = "No ticket types yet",
                Description = "Save the event first, then add ticket types so customers can purchase tickets.",
                Icon = "bi-ticket-perforated",
                ActionLabel = "Add ticket type",
                ActionUrl = Url.Action("Create", "TicketType", new { eventId = Model.EventId }),
                ActionIcon = "bi-plus-circle"
            })
        </section>
    }

    <div class="form-actions">
        <a class="btn btn--outline-secondary" asp-action="List" asp-controller="Event">
            <span>Cancel</span>
        </a>
        <button type="submit" class="btn btn--primary btn--lg">
            <i class="bi bi-check2-circle" aria-hidden="true"></i>
            <span>Save changes</span>
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script type="module" src="~/js/pages/event-form.js" asp-append-version="true"></script>
}
@model EventManagement.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Create account";
    Layout = "_Layout";
}

<div class="auth-shell">
    <aside class="auth-shell__visual" aria-hidden="true">
        <a class="auth-shell__brand" href="@Url.Action("List", "Event")">
            <span class="brand-mark brand-mark--sm">E</span>
            <span>EMS</span>
        </a>

        <div class="auth-shell__hero">
            <span class="auth-shell__eyebrow">Join EMS</span>
            <h1 class="auth-shell__title">
                Start with one<br />
                <em>good event</em>.
            </h1>
            <p class="auth-shell__lead">
                Whether you're attending your first gig or hosting your hundredth,
                EMS gives you the calm tools to make it effortless.
            </p>
        </div>

        <div class="auth-shell__stats">
            <div>
                <div class="auth-shell__stat-label">Setup time</div>
                <div class="auth-shell__stat-value">2 min</div>
            </div>
            <div>
                <div class="auth-shell__stat-label">It's free</div>
                <div class="auth-shell__stat-value">0đ</div>
            </div>
        </div>
    </aside>

    <section class="auth-shell__form">
        <div class="auth-shell__form-inner" style="max-width: 560px;">
            <header class="auth-shell__heading">
                <span class="auth-shell__heading-eyebrow">Create account</span>
                <h2 class="auth-shell__heading-title">Join EMS</h2>
                <p class="auth-shell__heading-subtitle">
                    A few details and you're in. Pick a role to get started.
                </p>
            </header>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="auth-error" role="alert">
                    <i class="bi bi-exclamation-circle" aria-hidden="true"></i>
                    <span>Please correct the highlighted fields and try again.</span>
                </div>
            }

            <form asp-action="Register" method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div style="display: flex; flex-direction: column; gap: var(--space-5);">
                    <div class="form-grid-2">
                        <div class="form-field" style="margin: 0;">
                            <label asp-for="FullName" class="form-label">
                                <span>Full name</span>
                                <span class="form-label__required" aria-hidden="true">*</span>
                            </label>
                            <input asp-for="FullName" class="form-control"
                                   autocomplete="name" placeholder="Jane Doe" />
                            <span asp-validation-for="FullName" class="field-validation-error"></span>
                        </div>

                        <div class="form-field" style="margin: 0;">
                            <label asp-for="Email" class="form-label">
                                <span>Email</span>
                                <span class="form-label__required" aria-hidden="true">*</span>
                            </label>
                            <input asp-for="Email" class="form-control"
                                   autocomplete="email" inputmode="email"
                                   placeholder="you@example.com" />
                            <span asp-validation-for="Email" class="field-validation-error"></span>
                        </div>
                    </div>

                    <div class="form-grid-2">
                        <div class="form-field" style="margin: 0;">
                            <label asp-for="Phone" class="form-label">Phone</label>
                            <input asp-for="Phone" class="form-control"
                                   autocomplete="tel" placeholder="Optional" />
                            <span asp-validation-for="Phone" class="field-validation-error"></span>
                        </div>

                        <div class="form-field" style="margin: 0;">
                            <label asp-for="Role" class="form-label">
                                <span>I want to</span>
                                <span class="form-label__required" aria-hidden="true">*</span>
                            </label>
                            <select asp-for="Role" class="form-select">
                                <option value="Customer">Buy tickets &amp; discover events</option>
                                <option value="Host">Host &amp; manage my own events</option>
                            </select>
                            <span class="field-hint">Customer for tickets. Host for publishing.</span>
                            <span asp-validation-for="Role" class="field-validation-error"></span>
                        </div>
                    </div>

                    <div class="form-grid-2">
                        <div class="form-field" style="margin: 0;">
                            <label asp-for="Password" class="form-label">
                                <span>Password</span>
                                <span class="form-label__required" aria-hidden="true">*</span>
                            </label>
                            <div class="form-control-shell">
                                <input asp-for="Password" class="form-control"
                                       autocomplete="new-password" placeholder="At least 6 characters" />
                                <button type="button"
                                        class="form-control-shell__action js-password-toggle"
                                        data-password-toggle="#Password"
                                        aria-pressed="false"
                                        aria-label="Show password">
                                    <i class="bi bi-eye" aria-hidden="true"></i>
                                </button>
                            </div>
                            <span class="field-hint">Minimum 6 characters.</span>
                            <span asp-validation-for="Password" class="field-validation-error"></span>
                        </div>

                        <div class="form-field" style="margin: 0;">
                            <label asp-for="ConfirmPassword" class="form-label">
                                <span>Confirm password</span>
                                <span class="form-label__required" aria-hidden="true">*</span>
                            </label>
                            <div class="form-control-shell">
                                <input asp-for="ConfirmPassword" class="form-control"
                                       autocomplete="new-password" placeholder="Re-enter your password" />
                                <button type="button"
                                        class="form-control-shell__action js-password-toggle"
                                        data-password-toggle="#ConfirmPassword"
                                        aria-pressed="false"
                                        aria-label="Show password">
                                    <i class="bi bi-eye" aria-hidden="true"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                        </div>
                    </div>

                    <button type="submit" class="btn btn--primary btn--block btn--lg js-register-submit">
                        <span>Create account</span>
                        <i class="bi bi-arrow-right" aria-hidden="true"></i>
                    </button>
                </div>
            </form>

            <div class="auth-shell__footer">
                Already have an account?
                <a asp-action="Login">Back to sign in</a>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script type="module" src="~/js/pages/account.js" asp-append-version="true"></script>
}
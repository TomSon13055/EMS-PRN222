@model List<EventManagement.ViewModels.VoucherListItemViewModel>
@{
    ViewData["Title"] = "My vouchers";
    Layout = "_Layout";

    var header = new EventManagement.ViewModels.PageHeaderViewModel
    {
        Title = "Vouchers",
        Subtitle = "Create vouchers to reward your customers and boost ticket sales.",
        Eyebrow = "EMS • Host",
        ActionLabel = "Create voucher",
        ActionUrl = Url.Action("Create", "Voucher"),
        ActionIcon = "bi-plus-circle"
    };
}

@await Html.PartialAsync("_PageHeader", header)

@if (Model.Any())
{
    <div class="data-table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Code</th>
                    <th class="numeric">Discount</th>
                    <th>Valid from</th>
                    <th>Valid to</th>
                    <th class="numeric">Usage</th>
                    <th>Status</th>
                    <th class="actions">Code</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in Model)
                {
                    <tr>
                        <td>
                            <span class="voucher-code-cell">
                                <i class="bi bi-tag-fill" aria-hidden="true"></i>
                                <span>@v.VoucherCode</span>
                            </span>
                        </td>
                        <td class="numeric">
                            <span class="voucher-discount">@v.DiscountPercentage.ToString("0.##")%</span>
                        </td>
                        <td class="text-secondary nowrap">@v.ValidFrom.ToString("dd MMM yyyy HH:mm")</td>
                        <td class="text-secondary nowrap">@v.ValidTo.ToString("dd MMM yyyy HH:mm")</td>
                        <td class="numeric">
                            <div class="text-strong">@v.UsedCount / @v.UsageLimit</div>
                            <small class="text-muted">used</small>
                        </td>
                        <td>
                            <partial name="_VoucherStatusBadge" model="new EventManagement.ViewModels.VoucherStatusViewModel
                            {
                                Now = DateTime.Now,
                                ValidFrom = v.ValidFrom,
                                ValidTo = v.ValidTo,
                                IsActive = v.IsActive,
                                UsedCount = v.UsedCount,
                                UsageLimit = v.UsageLimit
                            }" />
                        </td>
                        <td class="actions">
                            <button type="button" class="icon-btn"
                                    data-copy-button="#voucher-code-@v.VoucherId"
                                    aria-label="Copy code @v.VoucherCode">
                                <i class="bi bi-clipboard" aria-hidden="true"></i>
                            </button>
                            <span id="voucher-code-@v.VoucherId" class="sr-only">@v.VoucherCode</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    @await Html.PartialAsync("_EmptyState", new EventManagement.ViewModels.EmptyStateViewModel
    {
        Title = "No vouchers yet",
        Description = "Create your first voucher to give your customers a discount on tickets.",
        Icon = "bi-gift",
        ActionLabel = "Create your first voucher",
        ActionUrl = Url.Action("Create", "Voucher"),
        ActionIcon = "bi-plus-circle"
    })
}

@section Scripts {
    <script type="module" src="~/js/pages/vouchers.js" asp-append-version="true"></script>
}
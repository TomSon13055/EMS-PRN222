@model EventManagement.ViewModels.CreateVoucherViewModel
@{
    ViewData["Title"] = "Create Voucher";
    Layout = "_Layout";
}
<h2>Create Voucher</h2>
<form asp-action="Create" method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label class="form-label">Voucher Code</label>
        <input asp-for="VoucherCode" id="txt_voucherCode" class="form-control" />
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Discount Percentage</label>
            <input asp-for="DiscountPercentage" id="txt_discountPercentage" class="form-control" type="number" step="0.01" min="0.01" max="100" />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Usage Limit</label>
            <input asp-for="UsageLimit" id="txt_usageLimit" class="form-control" type="number" min="1" />
        </div>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Valid From</label>
            <input asp-for="ValidFrom" id="txt_validFrom" class="form-control" type="datetime-local" value="@Model.ValidFrom.ToString("yyyy-MM-ddTHH:mm")" />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Valid To</label>
            <input asp-for="ValidTo" id="txt_validTo" class="form-control" type="datetime-local" value="@Model.ValidTo.ToString("yyyy-MM-ddTHH:mm")" />
        </div>
    </div>
    <div class="form-check mb-3">
        <input asp-for="IsActive" id="chk_isActive" class="form-check-input" type="checkbox" />
        <label class="form-check-label" for="chk_isActive">Is Active</label>
    </div>
    <button id="btn_create" type="submit" class="btn btn-primary">Create</button>
    <a id="btn_back" asp-action="List" class="btn btn-link">Back</a>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

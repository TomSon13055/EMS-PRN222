@model EventManagement.ViewModels.EventDetailViewModel
@{
    ViewData["Title"] = Model.Title;
    Layout = "_Layout";

    var canBuy = ViewBag.CanBuy == true;
    var canWishlist = ViewBag.CanWishlist == true;
    var canEdit = ViewBag.CanEdit == true;
}

<nav class="breadcrumb" aria-label="Breadcrumb" style="margin-bottom: var(--spacing-4);">
    <a href="@Url.Action("Index", "Home")"><i class="bi bi-house"></i> Home</a>
    <span class="breadcrumb__separator" aria-hidden="true">/</span>
    <a href="@Url.Action("List", "Event")">Events</a>
    <span class="breadcrumb__separator" aria-hidden="true">/</span>
    <span class="breadcrumb__current">@Model.Title</span>
</nav>

<section class="vgt-event-hero">
    <div class="vgt-event-hero__bg @(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "vgt-event-hero__bg--gradient" : null)">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Title" />
        }
    </div>
    <div class="vgt-event-hero__overlay"></div>

    <div class="vgt-event-hero__content">
        <div class="vgt-event-hero__chips">
            @if (!string.IsNullOrWhiteSpace(Model.CategoryName))
            {
                <span class="vgt-event-hero__chip vgt-event-hero__chip--solid">
                    <i class="bi bi-tag-fill"></i> @Model.CategoryName
                </span>
            }
            <span class="vgt-event-hero__chip">
                <partial name="_StatusBadge" model="Model.Status" />
            </span>
        </div>

        <h1 class="vgt-event-hero__title">@Model.Title</h1>

        <div class="vgt-event-hero__meta">
            <span class="vgt-event-hero__meta-item">
                <i class="bi bi-calendar3"></i>
                <span>@Model.StartTime.ToString("dddd, dd MMM yyyy") &middot; @Model.StartTime.ToString("HH:mm") - @Model.EndTime.ToString("HH:mm")</span>
            </span>
            <span class="vgt-event-hero__meta-item">
                <i class="bi bi-geo-alt-fill"></i>
                <span>@Model.LocationName</span>
            </span>
            <span class="vgt-event-hero__meta-item">
                <i class="bi bi-person-circle"></i>
                <span>by @Model.HostName</span>
            </span>
        </div>
    </div>
</section>

<div class="vgt-info-grid">
    <div class="vgt-info-card">
        <span class="vgt-info-card__icon vgt-info-card__icon--iris"><i class="bi bi-calendar-event"></i></span>
        <span class="vgt-info-card__label">Starts</span>
        <span class="vgt-info-card__value">@Model.StartTime.ToString("dddd, dd MMM")</span>
        <span class="vgt-info-card__sub">@Model.StartTime.ToString("yyyy") &middot; @Model.StartTime.ToString("HH:mm") &mdash; @Model.EndTime.ToString("HH:mm")</span>
    </div>
    <div class="vgt-info-card">
        <span class="vgt-info-card__icon vgt-info-card__icon--pink"><i class="bi bi-geo-alt-fill"></i></span>
        <span class="vgt-info-card__label">Location</span>
        <span class="vgt-info-card__value">@Model.LocationName</span>
        @if (!string.IsNullOrWhiteSpace(Model.Address))
        {
            <span class="vgt-info-card__sub">@Model.Address</span>
        }
    </div>
    <div class="vgt-info-card">
        <span class="vgt-info-card__icon vgt-info-card__icon--amber"><i class="bi bi-person-badge"></i></span>
        <span class="vgt-info-card__label">Host</span>
        <span class="vgt-info-card__value">@Model.HostName</span>
        <span class="vgt-info-card__sub">Event organizer</span>
    </div>
    <div class="vgt-info-card">
        <span class="vgt-info-card__icon vgt-info-card__icon--emerald"><i class="bi bi-ticket-perforated"></i></span>
        <span class="vgt-info-card__label">Availability</span>
        <span class="vgt-info-card__value">@Model.TotalAvailableTickets <span style="font-size: 0.7em; font-weight: 500; color: var(--text-muted);">tickets</span></span>
        <span class="vgt-info-card__sub">@Model.TicketTypeCount ticket type@(Model.TicketTypeCount == 1 ? "" : "s") available</span>
    </div>
</div>

<section class="vgt-section">
    <div class="vgt-section__header">
        <div class="vgt-section__title-wrap">
            <h2 class="vgt-section__title">About this event</h2>
            <span class="vgt-section__subtitle">Everything you need to know before you go.</span>
        </div>
        <div class="vgt-section__actions">
            @if (canBuy)
            {
                <a class="btn btn--vgt-primary" href="@Url.Action("Buy", "Ticket", new { eventId = Model.EventId })">
                    <i class="bi bi-cart3" aria-hidden="true"></i>
                    <span>Buy ticket</span>
                </a>
            }
            @if (canWishlist)
            {
                <form method="post" asp-controller="Wishlist" asp-action="Add" asp-route-eventId="@Model.EventId" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn--vgt-outline">
                        <i class="bi bi-heart" aria-hidden="true"></i>
                        <span>Add to wishlist</span>
                    </button>
                </form>
            }
            @if (canEdit)
            {
                <a class="btn btn--secondary" href="@Url.Action("Edit", "Event", new { id = Model.EventId })">
                    <i class="bi bi-pencil" aria-hidden="true"></i>
                    <span>Edit event</span>
                </a>
            }
            <a class="btn btn--ghost" href="@Url.Action("List", "Event")">
                <i class="bi bi-arrow-left" aria-hidden="true"></i>
                <span>Back</span>
            </a>
        </div>
    </div>
    <div class="vgt-section__body">
        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p style="white-space: pre-line; color: var(--text-secondary); line-height: var(--line-height-relaxed); font-size: var(--font-size-md);">@Model.Description</p>
        }
        else
        {
            <p class="text-muted">No description provided.</p>
        }
    </div>
</section>

<section class="vgt-section" style="margin-top: var(--spacing-6);">
    <div class="vgt-section__header">
        <div class="vgt-section__title-wrap">
            <h2 class="vgt-section__title">Choose your ticket</h2>
            <span class="vgt-section__subtitle">Pick the experience that fits you best.</span>
        </div>
    </div>
    <div class="vgt-section__body">
        @if (Model.TicketTypes.Any())
        {
            <div class="ticket-type-list">
                @for (var idx = 0; idx < Model.TicketTypes.Count; idx++)
                {
                    var t = Model.TicketTypes[idx];
                    var variant = idx == 0 ? "vgt-ticket--recommended"
                                  : idx == 1 ? "vgt-ticket--vip"
                                  : "";
                    var badgeText = idx == 0 ? "Popular"
                                    : idx == 1 ? "Premium"
                                    : null;
                    var badgeClass = idx == 0 ? "vgt-ticket__badge--recommended"
                                     : idx == 1 ? "vgt-ticket__badge--vip"
                                     : "";

                    var totalStock = t.Quantity > 0 ? t.Quantity : 1;
                    var soldPercent = t.Quantity > 0 ? (int)Math.Round((double)(t.Quantity - t.Available) / totalStock * 100) : 0;
                    var stockLabel = "In stock";
                    var stockClass = "";
                    if (t.Available <= 0) { stockLabel = "Sold out"; stockClass = "--critical"; }
                    else if (t.Available < 10) { stockLabel = "Only a few left"; stockClass = "--low"; }

                    <article class="vgt-ticket @variant">
                        <header class="vgt-ticket__header">
                            <h3 class="vgt-ticket__name">@t.TypeName</h3>
                            @if (!string.IsNullOrEmpty(badgeText))
                            {
                                <span class="vgt-ticket__badge @badgeClass">@badgeText</span>
                            }
                        </header>
                        <div class="vgt-ticket__price">
                            @t.Price.ToString("N0")<span class="vgt-ticket__price-currency">đ</span>
                        </div>
                        <div class="vgt-ticket__meta">
                            <span>
                                <strong>@t.Available</strong> / @t.Quantity available
                            </span>
                            <span>Sale ends @t.SaleEnd.ToString("dd MMM HH:mm")</span>
                        </div>
                        <div>
                            <div class="vgt-ticket__stock-bar" aria-hidden="true">
                                <div class="vgt-ticket__stock-fill @stockClass" style="width: @soldPercent%;"></div>
                            </div>
                            <span class="text-secondary" style="font-size: var(--font-size-xs); margin-top: 6px; display: inline-block;">@stockLabel</span>
                        </div>
                        @if (canBuy && t.Status == "Active" && t.Available > 0)
                        {
                            <a class="btn btn--vgt-primary"
                               href="@Url.Action("Buy", "Ticket", new { eventId = Model.EventId, selectedTicketTypeId = t.TicketTypeId })">
                                <span>Buy this ticket</span>
                                <i class="bi bi-arrow-right" aria-hidden="true"></i>
                            </a>
                        }
                        else
                        {
                            <button class="btn btn--secondary" disabled aria-disabled="true">
                                <i class="bi bi-slash-circle"></i>
                                <span>@(t.Available <= 0 ? "Sold out" : "Unavailable")</span>
                            </button>
                        }
                    </article>
                }
            </div>
        }
        else
        {
            @await Html.PartialAsync("_EmptyState", new EventManagement.ViewModels.EmptyStateViewModel
            {
                Title = "No ticket types yet",
                Description = "The host hasn't published any tickets for this event yet. Please check back later.",
                Icon = "bi-ticket-perforated",
                IconVariant = "neutral"
            })
        }
    </div>
</section>
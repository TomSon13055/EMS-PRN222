@model EventManagement.ViewModels.MyTicketsPageViewModel
@{
    ViewData["Title"] = "My tickets";
    Layout = "_Layout";

    var header = new EventManagement.ViewModels.PageHeaderViewModel
    {
        Title = "My tickets",
        Subtitle = "All your purchased tickets. Show the QR code at the door for check-in.",
        Eyebrow = "EMS • Customer"
    };
}

@await Html.PartialAsync("_PageHeader", header)

<section class="tickets-summary-grid">
    <div class="summary-card">
        <span class="summary-card__label">Total</span>
        <span class="summary-card__value" id="span_totalTickets">@Model.TotalTickets</span>
        <span class="summary-card__hint">Tickets owned</span>
    </div>
    <div class="summary-card summary-card--primary">
        <span class="summary-card__label">Assigned</span>
        <span class="summary-card__value" id="span_assignedTickets">@Model.AssignedTickets</span>
        <span class="summary-card__hint">Ready to use</span>
    </div>
    <div class="summary-card summary-card--success">
        <span class="summary-card__label">Used</span>
        <span class="summary-card__value" id="span_usedTickets">@Model.UsedTickets</span>
        <span class="summary-card__hint">Checked in</span>
    </div>
    <div class="summary-card summary-card--amber">
        <span class="summary-card__label">Refunded</span>
        <span class="summary-card__value" id="span_refundedTickets">@Model.RefundedTickets</span>
        <span class="summary-card__hint">Returned</span>
    </div>
</section>

<form method="get" class="tickets-toolbar" data-my-tickets-filter>
    <div class="form-field" style="margin: 0;">
        <label class="form-label">Status</label>
        <select name="status" class="form-select" data-my-tickets-status>
            @foreach (var s in Model.Statuses)
            {
                <option value="@s.Value" selected="@(string.Equals(Model.Status ?? "All", s.Value, StringComparison.OrdinalIgnoreCase))">@s.Text</option>
            }
        </select>
    </div>
    <div class="form-field" style="margin: 0;">
        <label class="form-label">Search</label>
        <input type="search" name="search" value="@Model.Search"
               class="form-control" placeholder="Search by event or serial number" />
    </div>
    <button type="submit" class="btn btn--primary">
        <i class="bi bi-funnel" aria-hidden="true"></i>
        <span>Filter</span>
    </button>
</form>

@if (Model.Tickets.Any())
{
    <div class="data-table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Ticket</th>
                    <th>Event</th>
                    <th>Ticket type</th>
                    <th class="numeric">Price</th>
                    <th>Status</th>
                    <th>Issued at</th>
                    <th class="actions">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model.Tickets)
                {
                    <tr>
                        <td>
                            <div class="table-title">#@t.TicketId</div>
                            <code class="serial" title="@t.SerialNumber">@t.SerialNumber</code>
                        </td>
                        <td class="table-title">@t.EventTitle</td>
                        <td>@t.TicketTypeName</td>
                        <td class="numeric">@t.Price.ToString("N0") đ</td>
                        <td><partial name="_StatusBadge" model="t.Status" /></td>
                        <td class="text-secondary nowrap">@t.IssuedAt.ToString("dd MMM yyyy HH:mm")</td>
                        <td class="actions">
                            <a class="btn btn--secondary btn--sm"
                               href="@Url.Action("QR", "Ticket", new { id = t.TicketId })">
                                <i class="bi bi-qr-code" aria-hidden="true"></i>
                                <span>View QR</span>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    @await Html.PartialAsync("_EmptyState", new EventManagement.ViewModels.EmptyStateViewModel
    {
        Title = "No tickets yet",
        Description = "Buy tickets to your favourite events and they will appear here.",
        Icon = "bi-ticket-perforated",
        ActionLabel = "Browse events",
        ActionUrl = Url.Action("List", "Event"),
        ActionIcon = "bi-arrow-right"
    })
}

@section Scripts {
    <script type="module" src="~/js/pages/my-tickets.js" asp-append-version="true"></script>
}
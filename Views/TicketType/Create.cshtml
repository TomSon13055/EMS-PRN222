@model EventManagement.ViewModels.CreateTicketTypeViewModel
@{
    ViewData["Title"] = "Create ticket type";
    Layout = "_Layout";
}

<nav aria-label="Breadcrumb" class="breadcrumb" style="margin-bottom: var(--space-6);">
    <a href="@Url.Action("MyEvents", "Host")">My events</a>
    <i class="bi bi-chevron-right breadcrumb__separator" aria-hidden="true"></i>
    @if (!string.IsNullOrEmpty(Model.EventTitle))
    {
        <a href="@Url.Action("Edit", "Event", new { id = Model.EventId })">@Model.EventTitle</a>
        <i class="bi bi-chevron-right breadcrumb__separator" aria-hidden="true"></i>
    }
    <span class="breadcrumb__current">New ticket type</span>
</nav>

<header class="page-header page-header--compact" style="border-bottom: 0;">
    <div class="page-header__titles">
        <span class="page-header__eyebrow">Tickets</span>
        <h1 class="page-header__title">
            @if (!string.IsNullOrEmpty(Model.EventTitle))
            {
                <text>Add a ticket type for @Model.EventTitle.</text>
            }
            else
            {
                <text>Add a new ticket type.</text>
            }
        </h1>
        <p class="page-header__subtitle">Define the name, price and quantity. You can edit these later if needed.</p>
    </div>
</header>

<form asp-action="Create" method="post" novalidate style="max-width: var(--content-form-width);">
    <input type="hidden" asp-for="EventId" />
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>

    <section class="form-section">
        <span class="form-section__step">01 · Ticket details</span>
        <h2 class="form-section__title">The basics</h2>
        <p class="form-section__subtitle">Name the type and decide the price and quantity.</p>

        <div class="form-field">
            <label asp-for="TypeName" class="form-label">
                <span>Type name</span>
                <span class="form-label__required" aria-hidden="true">*</span>
            </label>
            <input asp-for="TypeName" class="form-control" maxlength="100"
                   placeholder="e.g. Standard, VIP, Early Bird" />
            <span asp-validation-for="TypeName" class="field-validation-error"></span>
        </div>

        <div class="form-grid-2">
            <div class="form-field" style="margin: 0;">
                <label asp-for="Price" class="form-label">
                    <span>Price</span>
                    <span class="form-label__required" aria-hidden="true">*</span>
                </label>
                <input asp-for="Price" class="form-control numeric" type="number" step="0.01" min="0.01"
                       placeholder="0.00" />
                <span class="field-hint">Price in VND. Free if set to 0 (not allowed here).</span>
                <span asp-validation-for="Price" class="field-validation-error"></span>
            </div>

            <div class="form-field" style="margin: 0;">
                <label asp-for="Quantity" class="form-label">
                    <span>Quantity</span>
                    <span class="form-label__required" aria-hidden="true">*</span>
                </label>
                <input asp-for="Quantity" class="form-control numeric" type="number" min="1" />
                <span class="field-hint">Total tickets available.</span>
                <span asp-validation-for="Quantity" class="field-validation-error"></span>
            </div>
        </div>
    </section>

    <section class="form-section">
        <span class="form-section__step">02 · Sale window</span>
        <h2 class="form-section__title">When customers can buy</h2>
        <p class="form-section__subtitle">Set a start and end date for the sale window.</p>

        <div class="form-grid-2">
            <div class="form-field" style="margin: 0;">
                <label asp-for="SaleStart" class="form-label">
                    <span>Sale start</span>
                    <span class="form-label__required" aria-hidden="true">*</span>
                </label>
                <input asp-for="SaleStart" type="datetime-local" class="form-control"
                       value="@(Model.SaleStart == default ? string.Empty : Model.SaleStart.ToString("yyyy-MM-ddTHH:mm"))" />
                <span asp-validation-for="SaleStart" class="field-validation-error"></span>
            </div>
            <div class="form-field" style="margin: 0;">
                <label asp-for="SaleEnd" class="form-label">
                    <span>Sale end</span>
                    <span class="form-label__required" aria-hidden="true">*</span>
                </label>
                <input asp-for="SaleEnd" type="datetime-local" class="form-control"
                       value="@(Model.SaleEnd == default ? string.Empty : Model.SaleEnd.ToString("yyyy-MM-ddTHH:mm"))" />
                <span class="field-hint">Sale end must be before the event starts.</span>
                <span asp-validation-for="SaleEnd" class="field-validation-error"></span>
            </div>
        </div>
    </section>

    <section class="form-section">
        <span class="form-section__step">03 · Status</span>
        <h2 class="form-section__title">Visibility</h2>
        <div class="form-field" style="max-width: 320px;">
            <label asp-for="Status" class="form-label">Status</label>
            <select asp-for="Status" class="form-select">
                <option value="Active" selected="@(Model.Status == "Active")">Active</option>
                <option value="Inactive" selected="@(Model.Status == "Inactive")">Inactive</option>
            </select>
            <span class="field-hint">Inactive tickets are hidden from the purchase flow.</span>
            <span asp-validation-for="Status" class="field-validation-error"></span>
        </div>
    </section>

    <div class="form-actions">
        <a class="btn btn--outline-secondary" asp-action="MyEvents" asp-controller="Host">
            <span>Cancel</span>
        </a>
        <button type="submit" class="btn btn--primary btn--lg">
            <i class="bi bi-check2-circle" aria-hidden="true"></i>
            <span>Create ticket type</span>
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
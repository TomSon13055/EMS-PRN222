@model EventManagement.ViewModels.CreateTicketTypeViewModel
@{
    ViewData["Title"] = "Create Ticket Type";
    Layout = "_Layout";
}
<h2>Create Ticket Type</h2>
@if (!string.IsNullOrEmpty(Model.EventTitle))
{
    <p>For event: <strong>@Model.EventTitle</strong></p>
}
<form asp-action="Create" method="post" class="mt-3">
    <input type="hidden" asp-for="EventId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label class="form-label">Type Name</label>
        <input asp-for="TypeName" id="txt_typeName" class="form-control" />
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Price</label>
            <input asp-for="Price" id="txt_price" class="form-control" type="number" step="0.01" min="0.01" />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Quantity</label>
            <input asp-for="Quantity" id="txt_quantity" class="form-control" type="number" min="1" />
        </div>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Sale Start</label>
            <input asp-for="SaleStart" id="txt_saleStart" class="form-control" type="datetime-local" value="@Model.SaleStart.ToString("yyyy-MM-ddTHH:mm")" />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Sale End</label>
            <input asp-for="SaleEnd" id="txt_saleEnd" class="form-control" type="datetime-local" value="@Model.SaleEnd.ToString("yyyy-MM-ddTHH:mm")" />
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label">Status</label>
        <select asp-for="Status" id="sl_status" class="form-select">
            <option value="Active" selected="@(Model.Status == "Active")">Active</option>
            <option value="Inactive" selected="@(Model.Status == "Inactive")">Inactive</option>
        </select>
    </div>
    <button id="btn_create" type="submit" class="btn btn-primary">Create</button>
    <a id="btn_back" asp-action="MyEvents" asp-controller="Host" class="btn btn-link">Back</a>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

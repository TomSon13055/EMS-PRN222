@model EventManagement.ViewModels.BuyTicketViewModel
@{
    ViewData["Title"] = "Buy Ticket";
    Layout = "_Layout";
    string fmt(DateTime d) => d.ToString("yyyy-MM-dd HH:mm");
}
<h2>Buy Ticket</h2>

@if (!string.IsNullOrEmpty(Model.EventTitle))
{
    <div class="card mb-3">
        <div class="card-body">
            <h4>@Model.EventTitle</h4>
            @if (!string.IsNullOrEmpty(Model.EventDescription))
            {
                <p>@Model.EventDescription</p>
            }
            @if (Model.EventStartTime.HasValue)
            {
                <p class="mb-0">
                    <strong>Start:</strong> @fmt(Model.EventStartTime.Value) |
                    <strong>Location:</strong> @Model.LocationName
                </p>
            }
        </div>
    </div>
}

@if (Model.TicketTypes == null || !Model.TicketTypes.Any())
{
    <div class="alert alert-warning">No ticket types available for this event.</div>
    <a asp-action="List" asp-controller="Event" class="btn btn-link">Back to Events</a>
    return;
}

<form asp-action="Buy" method="post" class="mt-3">
    <input type="hidden" asp-for="EventId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Ticket Type <span class="text-danger">*</span></label>
            <select asp-for="TicketTypeId" id="sl_ticketType" class="form-select" required>
                <option value="">-- Select Ticket Type --</option>
                @foreach (var t in Model.TicketTypes)
                {
                    var priceMatch = System.Text.RegularExpressions.Regex.Match(t.Text, @"\d[\d,]*").Value.Replace(",", "");
                    <option id="@("opt_ticketType_" + t.Value)" value="@t.Value" data-price="@priceMatch">@t.Text</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Quantity <span class="text-danger">*</span></label>
            <input asp-for="Quantity" id="txt_quantity" class="form-control" type="number" min="1" value="1" required />
        </div>
        <div class="col-md-3">
            <label class="form-label">Voucher Code (optional)</label>
            <input asp-for="VoucherCode" id="txt_voucherCode" class="form-control" placeholder="e.g. EMS10" />
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <button id="btn_applyVoucher" type="submit" formaction="/Ticket/ApplyVoucher" formmethod="post"
                    class="btn btn-outline-info w-100">
                Apply Voucher
            </button>
        </div>
    </div>

    <div class="mt-3" id="priceBreakdown">
        <table class="table table-sm">
            <tr>
                <td>SubTotal</td>
                <td class="text-end" id="subTotalDisplay">@((Model.SubTotal > 0 ? Model.SubTotal : 0).ToString("N0")) đ</td>
            </tr>
            @if (Model.VoucherApplied)
            {
                <tr class="text-success">
                    <td>Discount (@Model.VoucherCode)</td>
                    <td class="text-end" data-percentage="@Model.VoucherDiscountPercent">-@Model.DiscountAmount.ToString("N0") đ</td>
                </tr>
            }
            <tr class="fw-bold">
                <td>Final Amount</td>
                <td class="text-end" id="finalAmountDisplay">@Model.FinalAmount.ToString("N0") đ</td>
            </tr>
        </table>
        @if (Model.VoucherApplied && !string.IsNullOrEmpty(Model.VoucherMessage))
        {
            <small class="text-success">@Model.VoucherMessage</small>
        }
    </div>

    <div class="mt-3">
        <button id="btn_buy" type="submit" class="btn btn-primary px-4">
            Buy Ticket@(Model.VoucherApplied ? $" (Pay " + Model.FinalAmount.ToString("N0") + " đ)" : "")
        </button>
        <a id="btn_back" asp-action="List" asp-controller="Event" class="btn btn-link">Cancel</a>
    </div>
</form>

<p class="mt-3 text-muted small">
    <em>* Tickets are deducted from your wallet balance. Make sure you have sufficient funds.</em>
</p>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function updatePrice(isInitial) {
            var sel = document.getElementById('sl_ticketType');
            var qtyInput = document.getElementById('txt_quantity');
            if (!sel || !qtyInput) return;
            var qty = parseInt(qtyInput.value) || 0;
            var selected = sel.options[sel.selectedIndex];
            if (!sel.value || qty <= 0 || !selected) {
                document.getElementById('subTotalDisplay').textContent = '0 đ';
                document.getElementById('finalAmountDisplay').textContent = '0 đ';
                return;
            }
            var price = parseFloat(selected.getAttribute('data-price')) || 0;
            var sub = price * qty;
            document.getElementById('subTotalDisplay').textContent = sub.toLocaleString('en-US') + ' đ';

            var voucherApplied = document.querySelector('#priceBreakdown tr.text-success td[data-percentage]') != null;
            if (!voucherApplied || isInitial) {
                var final = sub;
                var discountCell = document.querySelector('#priceBreakdown tr.text-success td[data-percentage]');
                if (discountCell) {
                    var percent = parseFloat(discountCell.getAttribute('data-percentage')) || 0;
                    var discount = Math.round(sub * percent / 100);
                    final = Math.max(0, sub - discount);
                    discountCell.textContent = '-' + discount.toLocaleString('en-US') + ' đ';
                }
                document.getElementById('finalAmountDisplay').textContent = final.toLocaleString('en-US') + ' đ';
            }
        }
        document.getElementById('sl_ticketType')?.addEventListener('change', function() {
            updatePrice(false);
        });
        document.getElementById('txt_quantity')?.addEventListener('input', function() {
            updatePrice(false);
        });
        updatePrice(true);
    </script>
    <script>
        document.querySelector('form').addEventListener('submit', function (e) {
            var btn = document.getElementById('btn_buy');
            if (btn && !btn.disabled) {
                btn.disabled = true;
                btn.textContent = 'Processing...';
            }
        });
    </script>
}

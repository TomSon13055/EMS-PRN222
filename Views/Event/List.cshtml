@model EventManagement.ViewModels.EventListPageViewModel
@using EventManagement.Helpers
@{
    ViewData["Title"] = "Discover events";
    Layout = "_Layout";

    var hasFilters = Model.Filter.CategoryId.HasValue
        || Model.Filter.LocationId.HasValue
        || !string.IsNullOrEmpty(Model.Filter.Status)
        || !string.IsNullOrEmpty(Model.Filter.Search);
    var totalCount = Model.TotalCount ?? Model.Events.Count;
}

<section class="page-hero">
    <div class="page-hero__body">
        <span class="page-hero__eyebrow"><span class="accent-line"></span> What's on this season</span>
        <h1 class="page-hero__title">
            Find an event<br />
            worth <em>showing up</em> for.
        </h1>
        <p class="page-hero__lead">
            A curated mix of concerts, workshops, conferences and community gatherings —
            curated, ticketed and waiting for you.
        </p>
        <div class="page-hero__meta">
            <span class="eyebrow eyebrow--muted">@totalCount event@(totalCount == 1 ? "" : "s") live</span>
            <span class="page-hero__meta-dot"></span>
            <span>Updated daily</span>
        </div>
    </div>
    <aside class="page-hero__visual" aria-hidden="true">
        <div class="page-hero__visual-inner">
            <span class="page-hero__visual-tag">EMS · curated</span>
            <div class="page-hero__visual-stats">
                <div>
                    <div class="page-hero__visual-stat-label">Curated this month</div>
                    <div class="page-hero__visual-stat-value">@totalCount<span class="page-hero__visual-stat-suffix">events</span></div>
                </div>
                <div>
                    <div class="page-hero__visual-stat-label">Trusted by</div>
                    <div class="page-hero__visual-stat-value">120<span class="page-hero__visual-stat-suffix">hosts</span></div>
                </div>
            </div>
        </div>
    </aside>
</section>

<form method="get" asp-action="List" class="filter-bar" aria-label="Filter events">
    <div class="filter-bar__search">
        <i class="bi bi-search" aria-hidden="true"></i>
        <input type="search" name="search" value="@Model.Filter.Search"
               class="form-control" placeholder="Search by event title or description"
               autocomplete="off" data-search-input />
    </div>
    <div class="filter-bar__select">
        <label class="form-label">Category</label>
        <select name="categoryId" class="form-select">
            @foreach (var c in Model.Categories)
            {
                <option value="@c.Value" selected="@(string.Equals(Model.Filter.CategoryId?.ToString(), c.Value, StringComparison.Ordinal))">@c.Text</option>
            }
        </select>
    </div>
    <div class="filter-bar__select">
        <label class="form-label">Location</label>
        <select name="locationId" class="form-select">
            @foreach (var l in Model.Locations)
            {
                <option value="@l.Value" selected="@(string.Equals(Model.Filter.LocationId?.ToString(), l.Value, StringComparison.Ordinal))">@l.Text</option>
            }
        </select>
    </div>
    <div class="filter-bar__select">
        <label class="form-label">Status</label>
        <select name="status" class="form-select">
            @foreach (var s in Model.Statuses)
            {
                <option value="@s.Value" selected="@(string.Equals(Model.Filter.Status ?? string.Empty, s.Value, StringComparison.Ordinal))">@s.Text</option>
            }
        </select>
    </div>
    <div class="filter-bar__actions">
        <button type="submit" class="btn btn--primary">
            <span>Refine results</span>
            <i class="bi bi-arrow-right" aria-hidden="true"></i>
        </button>
        @if (hasFilters)
        {
            <a asp-action="List" class="btn btn--ghost" title="Clear filters">
                <i class="bi bi-x-lg" aria-hidden="true"></i>
                <span>Clear</span>
            </a>
        }
    </div>
</form>

<div class="section-block">
    <header class="section-heading">
        <div class="section-heading__titles">
            <span class="section-heading__eyebrow">All events</span>
            <h2 class="section-heading__title">@totalCount result@(totalCount == 1 ? "" : "s")</h2>
            <p class="section-heading__subtitle">
                @if (hasFilters)
                {
                    <text>Filtered view · Use clear to see everything.</text>
                }
                else
                {
                    <text>Browse the latest additions across categories and locations.</text>
                }
            </p>
        </div>
    </header>

    @if (Model.Events.Any())
    {
        <div class="event-grid">
            @foreach (var item in Model.Events)
            {
                @await Html.PartialAsync("_EventCard", EventManagement.ViewModels.EventCardViewModel.FromListItem(item))
            }
        </div>
    }
    else
    {
        @await Html.PartialAsync("_EmptyState", new EventManagement.ViewModels.EmptyStateViewModel
        {
            Title = "Nothing matches your filters",
            Description = "We couldn't find any events with those filters. Try clearing them or searching for something specific.",
            Icon = "bi-calendar2-x",
            ActionLabel = "Clear filters",
            ActionUrl = Url.Action("List", "Event"),
            ActionIcon = "bi-arrow-counterclockwise"
        })
    }
</div>

@await Html.PartialAsync("_Pagination", Model.Pagination)
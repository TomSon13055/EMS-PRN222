@model EventManagement.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign in";
    Layout = "_Layout";
}

<section class="auth-shell">
    <div class="auth-card">
        <div class="auth-card__brand">
            <span class="auth-card__brand-mark" aria-hidden="true">E</span>
            <span class="text-strong">Event Management System</span>
        </div>
        <h1 class="auth-card__title">Welcome back</h1>
        <p class="auth-card__subtitle">Sign in to manage your events, tickets and wallet.</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-error" role="alert">
                <i class="bi bi-exclamation-circle" aria-hidden="true"></i>
                <span>Please check your email and password and try again.</span>
            </div>
        }

        <form asp-action="Login" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-field">
                <label asp-for="Email" class="form-label">
                    <span>Email</span>
                    <span class="form-label__required" aria-hidden="true">*</span>
                </label>
                <div class="form-control-shell">
                    <span class="form-control-shell__icon" aria-hidden="true">
                        <i class="bi bi-envelope"></i>
                    </span>
                    <input asp-for="Email" class="form-control"
                           autocomplete="email" inputmode="email"
                           placeholder="you@example.com" />
                </div>
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="form-field">
                <label asp-for="Password" class="form-label">
                    <span>Password</span>
                    <span class="form-label__required" aria-hidden="true">*</span>
                </label>
                <div class="form-control-shell">
                    <span class="form-control-shell__icon" aria-hidden="true">
                        <i class="bi bi-shield-lock"></i>
                    </span>
                    <input asp-for="Password" class="form-control"
                           autocomplete="current-password"
                           placeholder="Enter your password" />
                    <button type="button"
                            class="form-control-shell__action js-password-toggle"
                            data-password-toggle="#Password"
                            aria-pressed="false"
                            aria-label="Show password">
                        <i class="bi bi-eye" aria-hidden="true"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>

            <button type="submit" class="btn btn--primary btn--block js-login-submit">
                <i class="bi bi-box-arrow-in-right" aria-hidden="true"></i>
                <span>Sign in</span>
            </button>
        </form>

        <div class="auth-card__footer">
            Don't have an account?
            <a asp-action="Register">Create one</a>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script type="module" src="~/js/pages/account.js" asp-append-version="true"></script>
}
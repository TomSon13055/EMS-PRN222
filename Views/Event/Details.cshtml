@model EventManagement.ViewModels.EventDetailViewModel
@{
    ViewData["Title"] = Model.Title;
    Layout = "_Layout";

    var canBuy = ViewBag.CanBuy == true;
    var canWishlist = ViewBag.CanWishlist == true;
    var canEdit = ViewBag.CanEdit == true;

    var startDate = Model.StartTime;
    var hasFree = Model.TicketTypes.Any(t => t.Price <= 0);
    var minPrice = Model.TicketTypes.Any() ? Model.TicketTypes.Min(t => t.Price) : (decimal?)null;
    var totalAvailable = Model.TotalAvailableTickets;
}

<nav aria-label="Breadcrumb" class="breadcrumb" style="margin-bottom: var(--space-6);">
    <a href="@Url.Action("List", "Event")">Events</a>
    <i class="bi bi-chevron-right breadcrumb__separator" aria-hidden="true"></i>
    @if (!string.IsNullOrWhiteSpace(Model.CategoryName))
    {
        <span>@Model.CategoryName</span>
        <i class="bi bi-chevron-right breadcrumb__separator" aria-hidden="true"></i>
    }
    <span class="breadcrumb__current">@Model.Title</span>
</nav>

<div class="event-detail__hero">
    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" alt="" />
    }
    else
    {
        <div class="event-detail__hero-placeholder" aria-hidden="true">
            <i class="bi bi-calendar-event"></i>
        </div>
    }
    <div class="event-detail__hero-inner">
        @if (!string.IsNullOrWhiteSpace(Model.CategoryName))
        {
            <span class="event-detail__hero-eyebrow">@Model.CategoryName</span>
        }
        <h1 class="event-detail__hero-title">@Model.Title</h1>
    </div>
</div>

<div class="event-detail">
    <div>
        <article class="event-detail__narrative">
            <span class="event-detail__section-title">About this event</span>
            <h3>The story</h3>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p>@Model.Description</p>
            }
            else
            {
                <p class="muted">No description has been provided for this event yet.</p>
            }
        </article>

        <article class="event-detail__narrative" style="margin-top: var(--space-12);">
            <span class="event-detail__section-title">The lineup</span>
            <h3>Hosts &amp; schedule</h3>
            <p>
                <strong>@Model.HostName</strong> is bringing this event to <strong>@Model.LocationName</strong>
                on <strong>@startDate.ToString("dddd, dd MMMM yyyy")</strong>
                from <strong>@startDate.ToString("HH:mm")</strong> to <strong>@Model.EndTime.ToString("HH:mm")</strong>.
            </p>
            @if (!string.IsNullOrWhiteSpace(Model.Address))
            {
                <p class="muted">Venue address · @Model.Address</p>
            }
        </article>

        <section style="margin-top: var(--space-12);">
            <header style="display: flex; align-items: end; justify-content: space-between; margin-bottom: var(--space-6); flex-wrap: wrap; gap: var(--space-4);">
                <div>
                    <span class="event-detail__section-title">Tickets</span>
                    <h3 style="font-family: var(--font-display); font-size: var(--text-2xl); color: var(--brand-ink); margin: 0;">
                        Choose your experience
                    </h3>
                </div>
                @if (Model.TicketTypes.Any())
                {
                    <span class="muted">@totalAvailable ticket@(totalAvailable == 1 ? "" : "s") left across @Model.TicketTypes.Count type@(Model.TicketTypes.Count == 1 ? "" : "s")</span>
                }
            </header>

            @if (Model.TicketTypes.Any())
            {
                <div class="ticket-type-list">
                    @foreach (var t in Model.TicketTypes)
                    {
                        var canBuyThis = canBuy && t.Status == "Active" && t.Available > 0;
                        <article class="ticket-type-row">
                            <div>
                                <h4 class="ticket-type-row__name">@t.TypeName</h4>
                                <div class="ticket-type-row__meta">
                                    <span><strong>@t.Available</strong> of @t.Quantity available</span>
                                    <span class="muted">Sale ends @t.SaleEnd.ToString("dd MMM, HH:mm")</span>
                                    <partial name="_StatusBadge" model="t.Status" />
                                </div>
                            </div>
                            <div>
                                @if (canBuyThis)
                                {
                                    <a class="btn btn--primary btn--block"
                                       href="@Url.Action("Buy", "Ticket", new { eventId = Model.EventId, selectedTicketTypeId = t.TicketTypeId })">
                                        <span>Reserve</span>
                                        <i class="bi bi-arrow-right" aria-hidden="true"></i>
                                    </a>
                                }
                                else if (t.Available <= 0)
                                {
                                    <button class="btn btn--secondary btn--block" disabled>
                                        <span>Sold out</span>
                                    </button>
                                }
                                else if (canBuy)
                                {
                                    <a class="btn btn--secondary btn--block"
                                       href="@Url.Action("Buy", "Ticket", new { eventId = Model.EventId, selectedTicketTypeId = t.TicketTypeId })">
                                        <span>Buy</span>
                                    </a>
                                }
                            </div>
                            <div class="ticket-type-row__price">
                                @if (t.Price <= 0)
                                {
                                    <span style="color: var(--success);">Free</span>
                                }
                                else
                                {
                                    @t.Price.ToString("N0")<span style="font-size: 0.55em; margin-left: 2px;">đ</span>
                                }
                                <span class="ticket-type-row__price-suffix">per ticket</span>
                            </div>
                        </article>
                    }
                </div>
            }
            else
            {
                @await Html.PartialAsync("_EmptyState", new EventManagement.ViewModels.EmptyStateViewModel
                {
                    Title = "Tickets aren't on sale yet",
                    Description = "The host hasn't released tickets for this event. Check back soon.",
                    Icon = "bi-ticket-perforated"
                })
            }
        </section>
    </div>

    <aside class="event-detail__rail" aria-label="Quick info">
        @if (canBuy && Model.TicketTypes.Any())
        {
            <a class="btn btn--primary btn--block btn--lg"
               href="@Url.Action("Buy", "Ticket", new { eventId = Model.EventId })">
                <span>Get ticket</span>
                <i class="bi bi-arrow-right" aria-hidden="true"></i>
            </a>
        }

        <div class="event-detail__rail-block">
            <span class="event-detail__rail-label">When</span>
            <span class="event-detail__rail-value">@startDate.ToString("ddd, dd MMM")</span>
            <span class="event-detail__rail-sub">@startDate.ToString("HH:mm") – @Model.EndTime.ToString("HH:mm")</span>
        </div>

        <div class="event-detail__rail-block">
            <span class="event-detail__rail-label">Where</span>
            <span class="event-detail__rail-value">@Model.LocationName</span>
            @if (!string.IsNullOrWhiteSpace(Model.Address))
            {
                <span class="event-detail__rail-sub">@Model.Address</span>
            }
        </div>

        @if (minPrice.HasValue)
        {
            <div class="event-detail__rail-block">
                <span class="event-detail__rail-label">Starting from</span>
                <span class="event-detail__rail-value" style="font-family: var(--font-display); font-size: var(--text-2xl);">
                    @if (minPrice.Value <= 0)
                    {
                        <span style="color: var(--success);">Free</span>
                    }
                    else
                    {
                        @minPrice.Value.ToString("N0")<span style="font-size: 0.7em; margin-left: 2px;">đ</span>
                    }
                </span>
                <span class="event-detail__rail-sub">@totalAvailable ticket@(totalAvailable == 1 ? "" : "s") left</span>
            </div>
        }

        <div class="event-detail__rail-block">
            <span class="event-detail__rail-label">Hosted by</span>
            <span class="event-detail__rail-value">@Model.HostName</span>
        </div>

        <div class="event-detail__rail-block">
            <span class="event-detail__rail-label">Status</span>
            <span class="event-detail__rail-value">
                <partial name="_StatusBadge" model="Model.Status" />
            </span>
        </div>

        <div class="event-detail__rail-actions">
            @if (canWishlist)
            {
                <form method="post" asp-controller="Wishlist" asp-action="Add" asp-route-eventId="@Model.EventId">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn--secondary btn--block">
                        <i class="bi bi-heart" aria-hidden="true"></i>
                        <span>Save to wishlist</span>
                    </button>
                </form>
            }
            @if (canEdit)
            {
                <a class="btn btn--outline-secondary btn--block"
                   href="@Url.Action("Edit", "Event", new { id = Model.EventId })">
                    <i class="bi bi-pencil" aria-hidden="true"></i>
                    <span>Edit event</span>
                </a>
            }
            <a class="btn btn--ghost btn--block" href="@Url.Action("List", "Event")">
                <i class="bi bi-arrow-left" aria-hidden="true"></i>
                <span>Back to events</span>
            </a>
        </div>
    </aside>
</div>
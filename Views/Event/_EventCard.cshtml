@model EventManagement.ViewModels.EventCardViewModel

@{
    var statusVariant = (Model.Status ?? "").ToLowerInvariant() switch
    {
        "published" => "status-badge--success",
        "draft" => "status-badge--warning",
        "ongoing" => "status-badge--info",
        "completed" => "status-badge--neutral",
        "cancelled" => "status-badge--danger",
        _ => "status-badge--neutral"
    };
    var minPrice = Model.MinPrice;
    var hasPrice = minPrice.HasValue;
    var isFree = hasPrice && minPrice!.Value <= 0;
    var stock = Model.AvailableTickets;
    var stockClass = stock.HasValue && stock.Value <= 0 ? "event-card__stock event-card__stock--low"
        : stock.HasValue && stock.Value < 10 ? "event-card__stock event-card__stock--low" : "event-card__stock";
}

<article class="event-card" data-event-card data-event-id="@Model.EventId">
    <div class="event-card__media">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Title" loading="lazy" />
        }
        else
        {
            <i class="bi bi-calendar-event event-card__placeholder" aria-hidden="true"></i>
        }
        <div class="event-card__badges">
            @if (!string.IsNullOrWhiteSpace(Model.CategoryName))
            {
                <span class="status-badge status-badge--primary">@Model.CategoryName</span>
            }
            <span class="status-badge @statusVariant">@Model.Status</span>
        </div>
        @if (Model.CanWishlist)
        {
            <form class="event-card__wishlist" method="post"
                  asp-controller="Wishlist" asp-action="Add" asp-route-eventId="@Model.EventId">
                @Html.AntiForgeryToken()
                <button type="submit"
                        class="icon-btn icon-btn--danger"
                        aria-label="Add @Model.Title to wishlist">
                    <i class="bi bi-heart" aria-hidden="true"></i>
                </button>
            </form>
        }
    </div>

    <div class="event-card__body">
        <h3 class="event-card__title">
            <a href="@Url.Action("Details", "Event", new { id = Model.EventId })">@Model.Title</a>
        </h3>
        <div class="event-card__meta">
            <div class="event-card__meta-row">
                <i class="bi bi-calendar3" aria-hidden="true"></i>
                <span>@Model.StartTime.ToString("ddd, dd MMM yyyy")</span>
            </div>
            <div class="event-card__meta-row">
                <i class="bi bi-clock" aria-hidden="true"></i>
                <span>@Model.StartTime.ToString("HH:mm") - @Model.EndTime.ToString("HH:mm")</span>
            </div>
            <div class="event-card__meta-row">
                <i class="bi bi-geo-alt" aria-hidden="true"></i>
                <span>@Model.LocationName</span>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.HostName))
            {
                <div class="event-card__meta-row">
                    <i class="bi bi-person-circle" aria-hidden="true"></i>
                    <span>@Model.HostName</span>
                </div>
            }
        </div>
    </div>

    <div class="event-card__footer">
        <div class="event-card__price">
            <span class="event-card__price-label">From</span>
            @if (isFree)
            {
                <span class="event-card__price-value event-card__price-free">Free</span>
            }
            else if (hasPrice)
            {
                <span class="event-card__price-value">@minPrice!.Value.ToString("N0") &nbsp;đ</span>
            }
            else
            {
                <span class="event-card__price-value text-muted">&mdash;</span>
            }
            @if (stock.HasValue)
            {
                <span class="@stockClass">
                    @if (stock.Value <= 0)
                    {
                        <text>Sold out</text>
                    }
                    else
                    {
                        <text>@stock.Value tickets left</text>
                    }
                </span>
            }
        </div>
        <div class="action-group">
            <a class="btn btn--secondary btn--sm"
               href="@Url.Action("Details", "Event", new { id = Model.EventId })">
                <i class="bi bi-eye" aria-hidden="true"></i>
                <span>View</span>
            </a>
            @if (Model.CanBuy)
            {
                <a class="btn btn--primary btn--sm"
                   href="@Url.Action("Buy", "Ticket", new { eventId = Model.EventId })">
                    <i class="bi bi-cart3" aria-hidden="true"></i>
                    <span>Buy</span>
                </a>
            }
            @if (Model.CanEdit)
            {
                <a class="btn btn--outline-primary btn--sm"
                   href="@Url.Action("Edit", "Event", new { id = Model.EventId })">
                    <i class="bi bi-pencil" aria-hidden="true"></i>
                    <span>Edit</span>
                </a>
            }
        </div>
    </div>
</article>
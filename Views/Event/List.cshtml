@model EventManagement.ViewModels.EventListPageViewModel
@using EventManagement.Helpers
@{
    ViewData["Title"] = "Discover events";
    Layout = "_Layout";

    var header = new EventManagement.ViewModels.PageHeaderViewModel
    {
        Title = "Discover events",
        Subtitle = "Browse upcoming events, save them to your wishlist, and grab your tickets.",
        Eyebrow = "EMS • Events"
    };
}

@await Html.PartialAsync("_PageHeader", header)

<form method="get" asp-action="List" class="event-toolbar" aria-label="Filter events">
    <div class="field--category form-field" style="margin: 0;">
        <label class="form-label">Category</label>
        <select name="categoryId" class="form-select">
            @foreach (var c in Model.Categories)
            {
                <option value="@c.Value" selected="@(string.Equals(Model.Filter.CategoryId?.ToString(), c.Value, StringComparison.Ordinal))">@c.Text</option>
            }
        </select>
    </div>
    <div class="field--location form-field" style="margin: 0;">
        <label class="form-label">Location</label>
        <select name="locationId" class="form-select">
            @foreach (var l in Model.Locations)
            {
                <option value="@l.Value" selected="@(string.Equals(Model.Filter.LocationId?.ToString(), l.Value, StringComparison.Ordinal))">@l.Text</option>
            }
        </select>
    </div>
    <div class="field--status form-field" style="margin: 0;">
        <label class="form-label">Status</label>
        <select name="status" class="form-select">
            @foreach (var s in Model.Statuses)
            {
                <option value="@s.Value" selected="@(string.Equals(Model.Filter.Status ?? string.Empty, s.Value, StringComparison.Ordinal))">@s.Text</option>
            }
        </select>
    </div>
    <div class="field--search form-field" style="margin: 0;">
        <label class="form-label">Search</label>
        <input type="search" name="search" value="@Model.Filter.Search"
               class="form-control" placeholder="Search by title or description"
               data-search-input />
    </div>
    <div class="field--filter">
        <button type="submit" class="btn btn--primary">
            <i class="bi bi-funnel" aria-hidden="true"></i>
            <span>Filter</span>
        </button>
        <a asp-action="List" class="btn btn--ghost">
            <i class="bi bi-x-lg" aria-hidden="true"></i>
            <span>Clear</span>
        </a>
    </div>
</form>

<div class="event-results-meta">
    <span>Showing @Model.Events.Count event@(Model.Events.Count == 1 ? "" : "s")</span>
    @if (Model.Filter.CategoryId.HasValue || Model.Filter.LocationId.HasValue ||
         !string.IsNullOrEmpty(Model.Filter.Status) || !string.IsNullOrEmpty(Model.Filter.Search))
    {
        <span>Filters applied</span>
    }
</div>

@if (Model.Events.Any())
{
    <div class="event-grid">
        @foreach (var item in Model.Events)
        {
            @await Html.PartialAsync("_EventCard", EventManagement.ViewModels.EventCardViewModel.FromListItem(item))
        }
    </div>
}
else
{
    @await Html.PartialAsync("_EmptyState", new EventManagement.ViewModels.EmptyStateViewModel
    {
        Title = "No events found",
        Description = "Try adjusting your filters or clearing them to see all available events.",
        Icon = "bi-calendar-x",
        ActionLabel = "Clear filters",
        ActionUrl = Url.Action("List", "Event"),
        ActionIcon = "bi-arrow-counterclockwise"
    })
}
@model EventManagement.ViewModels.MyTicketsPageViewModel
@{
    ViewData["Title"] = "My tickets";
    Layout = "_Layout";
}

<header class="page-header page-header--compact">
    <div class="page-header__titles">
        <span class="page-header__eyebrow">Your digital wallet</span>
        <h1 class="page-header__title">My tickets.</h1>
        <p class="page-header__subtitle">
            All your purchased tickets in one place. Show the QR code at the door for check-in.
        </p>
    </div>
</header>

<section class="metric-strip" aria-label="Ticket overview">
    <div class="metric-strip__item">
        <span class="metric-strip__label">Total</span>
        <span class="metric-strip__value">@Model.TotalTickets</span>
        <span class="muted" style="font-size: var(--text-xs);">All tickets owned</span>
    </div>
    <div class="metric-strip__item metric-strip__item--accent">
        <span class="metric-strip__label">Assigned</span>
        <span class="metric-strip__value">@Model.AssignedTickets</span>
        <span class="muted" style="font-size: var(--text-xs);">Ready to use</span>
    </div>
    <div class="metric-strip__item">
        <span class="metric-strip__label">Used</span>
        <span class="metric-strip__value">@Model.UsedTickets</span>
        <span class="muted" style="font-size: var(--text-xs);">Checked in</span>
    </div>
    <div class="metric-strip__item">
        <span class="metric-strip__label">Refunded</span>
        <span class="metric-strip__value">@Model.RefundedTickets</span>
        <span class="muted" style="font-size: var(--text-xs);">Returned</span>
    </div>
</section>

<form method="get" class="tickets-toolbar" data-my-tickets-filter>
    <div class="form-field" style="margin: 0;">
        <label class="form-label">Status</label>
        <select name="status" class="form-select" data-my-tickets-status>
            @foreach (var s in Model.Statuses)
            {
                <option value="@s.Value" selected="@(string.Equals(Model.Status ?? "All", s.Value, StringComparison.OrdinalIgnoreCase))">@s.Text</option>
            }
        </select>
    </div>
    <div class="form-field" style="margin: 0; flex: 1; min-width: 240px;">
        <label class="form-label">Search</label>
        <input type="search" name="search" value="@Model.Search"
               class="form-control" placeholder="Search by event or serial number" />
    </div>
    <button type="submit" class="btn btn--primary">
        <i class="bi bi-funnel" aria-hidden="true"></i>
        <span>Filter</span>
    </button>
</form>

@if (Model.Tickets.Any())
{
    <div class="data-table-wrap">
        <table class="data-table data-table--compact">
            <thead>
                <tr>
                    <th style="width: 60px;">&nbsp;</th>
                    <th>Event</th>
                    <th>Ticket type</th>
                    <th class="numeric">Price</th>
                    <th>Status</th>
                    <th>Issued at</th>
                    <th class="actions">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model.Tickets)
                {
                    <tr>
                        <td>
                            <div class="row-event__media" aria-hidden="true">
                                <i class="bi bi-ticket-perforated"></i>
                            </div>
                        </td>
                        <td>
                            <div class="table-title">@t.EventTitle</div>
                            <code class="serial" title="@t.SerialNumber">@t.SerialNumber</code>
                        </td>
                        <td class="table-sub">@t.TicketTypeName</td>
                        <td class="numeric">@t.Price.ToString("N0") đ</td>
                        <td><partial name="_StatusBadge" model="t.Status" /></td>
                        <td class="text-secondary nowrap">@t.IssuedAt.ToString("dd MMM yyyy HH:mm")</td>
                        <td class="actions">
                            <a class="btn btn--secondary btn--sm"
                               href="@Url.Action("QR", "Ticket", new { id = t.TicketId })">
                                <i class="bi bi-qr-code" aria-hidden="true"></i>
                                <span>View QR</span>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    @await Html.PartialAsync("_EmptyState", new EventManagement.ViewModels.EmptyStateViewModel
    {
        Title = "No tickets yet",
        Description = "Buy tickets to your favourite events and they will appear here.",
        Icon = "bi-ticket-perforated",
        ActionLabel = "Browse events",
        ActionUrl = Url.Action("List", "Event"),
        ActionIcon = "bi-arrow-right"
    })
}

@section Scripts {
    <script type="module" src="~/js/pages/my-tickets.js" asp-append-version="true"></script>
}
@model EventManagement.ViewModels.EventListPageViewModel
@using EventManagement.Helpers
@{
    ViewData["Title"] = "Discover events";
    Layout = "_Layout";

    var hasFilter = Model.Filter.CategoryId.HasValue
                    || Model.Filter.LocationId.HasValue
                    || !string.IsNullOrEmpty(Model.Filter.Status)
                    || !string.IsNullOrEmpty(Model.Filter.Search);
}

<section class="vgt-hero" style="padding: clamp(2rem, 4vw, 3rem) clamp(1.5rem, 4vw, 3rem);">
    <div class="vgt-orb vgt-orb--iris"></div>
    <div class="vgt-orb vgt-orb--pink"></div>

    <span class="vgt-hero__eyebrow">
        <i class="bi bi-compass" aria-hidden="true"></i>
        EMS &middot; Discover
    </span>

    <h1 class="vgt-hero__title" style="max-width: 22ch;">
        Find your next <span class="vgt-text-gradient--bright">unforgettable</span> experience.
    </h1>

    <p class="vgt-hero__subtitle">
        Browse upcoming events, save them to your wishlist, and grab your tickets
        in just a few clicks.
    </p>
</section>

<form method="get" asp-action="List" class="vgt-filter" aria-label="Filter events" style="margin-top: var(--spacing-6);">
    <div class="vgt-filter__field vgt-filter__field--category">
        <label class="vgt-filter__label" for="filter-category">Category</label>
        <select id="filter-category" name="categoryId" class="vgt-filter__input">
            @foreach (var c in Model.Categories)
            {
                <option value="@c.Value" selected="@(string.Equals(Model.Filter.CategoryId?.ToString(), c.Value, StringComparison.Ordinal))">@c.Text</option>
            }
        </select>
    </div>
    <div class="vgt-filter__field vgt-filter__field--location">
        <label class="vgt-filter__label" for="filter-location">Location</label>
        <select id="filter-location" name="locationId" class="vgt-filter__input">
            @foreach (var l in Model.Locations)
            {
                <option value="@l.Value" selected="@(string.Equals(Model.Filter.LocationId?.ToString(), l.Value, StringComparison.Ordinal))">@l.Text</option>
            }
        </select>
    </div>
    <div class="vgt-filter__field vgt-filter__field--status">
        <label class="vgt-filter__label" for="filter-status">Status</label>
        <select id="filter-status" name="status" class="vgt-filter__input">
            @foreach (var s in Model.Statuses)
            {
                <option value="@s.Value" selected="@(string.Equals(Model.Filter.Status ?? string.Empty, s.Value, StringComparison.Ordinal))">@s.Text</option>
            }
        </select>
    </div>
    <div class="vgt-filter__field vgt-filter__field--search">
        <label class="vgt-filter__label" for="filter-search">Search</label>
        <div class="vgt-filter__search-wrap">
            <i class="bi bi-search" aria-hidden="true"></i>
            <input id="filter-search" type="search" name="search" value="@Model.Filter.Search"
                   class="vgt-filter__input" placeholder="Search by title or description"
                   data-search-input />
        </div>
    </div>
    <div class="vgt-filter__field vgt-filter__field--actions">
        <button type="submit" class="btn btn--vgt-primary">
            <i class="bi bi-funnel" aria-hidden="true"></i>
            <span>Filter</span>
        </button>
        <a asp-action="List" class="btn btn--secondary" aria-label="Clear filters">
            <i class="bi bi-x-lg" aria-hidden="true"></i>
            <span>Clear</span>
        </a>
    </div>
</form>

<div class="vgt-results-meta" style="margin-top: var(--spacing-5);">
    <span class="vgt-results-meta__count">
        Showing <strong>@Model.Events.Count</strong> event@(Model.Events.Count == 1 ? "" : "s")
    </span>
    @if (hasFilter)
    {
        <span class="status-badge status-badge--primary">
            <i class="bi bi-funnel-fill"></i> Filters applied
        </span>
    }
</div>

@if (Model.Events.Any())
{
    <div class="event-grid">
        @foreach (var item in Model.Events)
        {
            @await Html.PartialAsync("_EventCard", EventManagement.ViewModels.EventCardViewModel.FromListItem(item))
        }
    </div>
}
else
{
    @await Html.PartialAsync("_EmptyState", new EventManagement.ViewModels.EmptyStateViewModel
    {
        Title = "No events found",
        Description = "Try adjusting your filters or clearing them to see all available events.",
        Icon = "bi-calendar-x",
        ActionLabel = "Clear filters",
        ActionUrl = Url.Action("List", "Event"),
        ActionIcon = "bi-arrow-counterclockwise"
    })
}
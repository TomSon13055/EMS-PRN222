@model EventManagement.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Create account";
    Layout = "_Layout";
}

<section class="auth-shell">
    <div class="auth-card auth-card--wide">
        <div class="auth-card__brand">
            <span class="auth-card__brand-mark" aria-hidden="true">E</span>
            <span class="text-strong">Event Management System</span>
        </div>
        <h1 class="auth-card__title">Create your account</h1>
        <p class="auth-card__subtitle">Join EMS to discover events, buy tickets or host your own.</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-error" role="alert">
                <i class="bi bi-exclamation-circle" aria-hidden="true"></i>
                <span>Please correct the highlighted fields and try again.</span>
            </div>
        }

        <form asp-action="Register" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-grid-2">
                <div class="form-field">
                    <label asp-for="FullName" class="form-label">
                        <span>Full name</span>
                        <span class="form-label__required" aria-hidden="true">*</span>
                    </label>
                    <input asp-for="FullName" class="form-control"
                           autocomplete="name" placeholder="Jane Doe" />
                    <span asp-validation-for="FullName" class="field-validation-error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Email" class="form-label">
                        <span>Email</span>
                        <span class="form-label__required" aria-hidden="true">*</span>
                    </label>
                    <input asp-for="Email" class="form-control"
                           autocomplete="email" inputmode="email"
                           placeholder="you@example.com" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>
            </div>

            <div class="form-grid-2">
                <div class="form-field">
                    <label asp-for="Phone" class="form-label">Phone</label>
                    <input asp-for="Phone" class="form-control"
                           autocomplete="tel" placeholder="Optional" />
                    <span asp-validation-for="Phone" class="field-validation-error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Role" class="form-label">
                        <span>I want to</span>
                        <span class="form-label__required" aria-hidden="true">*</span>
                    </label>
                    <select asp-for="Role" class="form-select">
                        <option value="Customer">Buy tickets and discover events</option>
                        <option value="Host">Host and manage my own events</option>
                    </select>
                    <span class="field-hint">Customer for buying tickets. Host for publishing events.</span>
                    <span asp-validation-for="Role" class="field-validation-error"></span>
                </div>
            </div>

            <div class="form-grid-2">
                <div class="form-field">
                    <label asp-for="Password" class="form-label">
                        <span>Password</span>
                        <span class="form-label__required" aria-hidden="true">*</span>
                    </label>
                    <div class="form-control-shell">
                        <input asp-for="Password" class="form-control"
                               autocomplete="new-password" placeholder="At least 6 characters" />
                        <button type="button"
                                class="form-control-shell__action js-password-toggle"
                                data-password-toggle="#Password"
                                aria-pressed="false"
                                aria-label="Show password">
                            <i class="bi bi-eye" aria-hidden="true"></i>
                        </button>
                    </div>
                    <span class="field-hint">Minimum 6 characters.</span>
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <div class="form-field">
                    <label asp-for="ConfirmPassword" class="form-label">
                        <span>Confirm password</span>
                        <span class="form-label__required" aria-hidden="true">*</span>
                    </label>
                    <div class="form-control-shell">
                        <input asp-for="ConfirmPassword" class="form-control"
                               autocomplete="new-password" placeholder="Re-enter your password" />
                        <button type="button"
                                class="form-control-shell__action js-password-toggle"
                                data-password-toggle="#ConfirmPassword"
                                aria-pressed="false"
                                aria-label="Show password">
                            <i class="bi bi-eye" aria-hidden="true"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                </div>
            </div>

            <button type="submit" class="btn btn--primary btn--block js-register-submit">
                <i class="bi bi-person-plus" aria-hidden="true"></i>
                <span>Create account</span>
            </button>
        </form>

        <div class="auth-card__footer">
            Already have an account?
            <a asp-action="Login">Back to sign in</a>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script type="module" src="~/js/pages/account.js" asp-append-version="true"></script>
}
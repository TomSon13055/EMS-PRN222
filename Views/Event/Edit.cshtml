@model EventManagement.ViewModels.EditEventViewModel
@{
    ViewData["Title"] = "Edit Event";
    Layout = "_Layout";
}
<h2>Edit Event</h2>
<form asp-action="Edit" method="post" class="mt-3">
    <input type="hidden" asp-for="EventId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label class="form-label">Title</label>
        <input asp-for="Title" id="txt_title" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea asp-for="Description" id="txt_description" class="form-control" rows="4"></textarea>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Category</label>
            <select asp-for="EventCategoryId" id="sl_category" class="form-select">
                @if (Model.Categories != null)
                {
                    int idx = 0;
                    foreach (var c in Model.Categories)
                    {
                        idx++;
                        <option id="@("opt_category_" + idx)" value="@c.Value" selected="@(c.Value == Model.EventCategoryId.ToString())">@c.Text</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Location</label>
            <select asp-for="EventLocationId" id="sl_location" class="form-select">
                @if (Model.Locations != null)
                {
                    int idx = 0;
                    foreach (var l in Model.Locations)
                    {
                        idx++;
                        <option id="@("opt_location_" + idx)" value="@l.Value" selected="@(l.Value == Model.EventLocationId.ToString())">@l.Text</option>
                    }
                }
            </select>
        </div>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Start Time</label>
            <input asp-for="StartTime" id="txt_startTime" class="form-control" type="datetime-local" value="@Model.StartTime.ToString("yyyy-MM-ddTHH:mm")" />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">End Time</label>
            <input asp-for="EndTime" id="txt_endTime" class="form-control" type="datetime-local" value="@Model.EndTime.ToString("yyyy-MM-ddTHH:mm")" />
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label">Image URL</label>
        <input asp-for="ImageUrl" id="txt_imageUrl" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Status</label>
        <select asp-for="Status" id="sl_status" class="form-select">
            @if (Model.Statuses != null)
            {
                foreach (var s in Model.Statuses)
                {
                    <option value="@s.Value" selected="@(s.Value == Model.Status)">@s.Text</option>
                }
            }
        </select>
    </div>
    <button id="btn_save" type="submit" class="btn btn-primary">Save</button>
    <a id="btn_back" asp-action="List" asp-controller="Event" class="btn btn-link">Back</a>
</form>

<div class="mt-4">
    <h5>Ticket Types</h5>

    @if (Model.TicketTypes == null || !Model.TicketTypes.Any())
    {
        <div class="alert alert-warning">No ticket types yet. Click "Add Ticket Type" to create one.</div>
    }
    else
    {
        <table class="table table-bordered table-striped">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Sale Window</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model.TicketTypes)
                {
                    <tr>
                        <td>@t.TypeName</td>
                        <td>@t.Price.ToString("N0") đ</td>
                        <td>@t.Quantity</td>
                        <td>@t.SaleStart.ToString("yyyy-MM-dd HH:mm") – @t.SaleEnd.ToString("yyyy-MM-dd HH:mm")</td>
                        <td><span class="badge @(t.Status == "Active" ? "bg-success" : "bg-secondary")">@t.Status</span></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

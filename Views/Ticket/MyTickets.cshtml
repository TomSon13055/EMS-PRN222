@model EventManagement.ViewModels.MyTicketsPageViewModel
@{
    ViewData["Title"] = "My Tickets";
    Layout = "_Layout";
    string fmt(DateTime d) => d.ToString("yyyy-MM-dd HH:mm");
}
<h2>My Tickets</h2>
<p>
    Total: <span id="span_totalTickets">@Model.TotalTickets</span> |
    Assigned: <span id="span_assignedTickets">@Model.AssignedTickets</span> |
    Used: <span id="span_usedTickets">@Model.UsedTickets</span> |
    Refunded: <span id="span_refundedTickets">@Model.RefundedTickets</span>
</p>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <label class="form-label">Status</label>
        <select id="sl_status" name="status" class="form-select">
            @foreach (var s in Model.Statuses)
            {
                <option value="@s.Value" selected="@(s.Value == (Model.Status ?? "All"))">@s.Text</option>
            }
        </select>
    </div>
    <div class="col-md-7">
        <label class="form-label">Search</label>
        <input id="txt_search" name="search" value="@Model.Search" class="form-control" />
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button id="btn_filter" type="submit" class="btn btn-primary w-100">Filter</button>
    </div>
</form>

<table class="table table-bordered bg-white">
    <thead>
        <tr>
            <th>TicketId</th>
            <th>SerialNumber</th>
            <th>EventTitle</th>
            <th>TicketTypeName</th>
            <th>Price</th>
            <th>Status</th>
            <th>IssuedAt</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Tickets.Any())
        {
            <tr><td colspan="8" class="text-center">No tickets</td></tr>
        }
        @foreach (var t in Model.Tickets)
        {
            <tr>
                <td id="@("td_ticketId_" + t.TicketId)">@t.TicketId</td>
                <td id="@("td_serialNumber_" + t.TicketId)">@t.SerialNumber</td>
                <td id="@("td_eventTitle_" + t.TicketId)">@t.EventTitle</td>
                <td id="@("td_ticketTypeName_" + t.TicketId)">@t.TicketTypeName</td>
                <td id="@("td_price_" + t.TicketId)">@t.Price.ToString("N0") đ</td>
                <td id="@("td_status_" + t.TicketId)">@t.Status</td>
                <td id="@("td_issuedAt_" + t.TicketId)">@fmt(t.IssuedAt)</td>
                <td>
                    <a id="@("lnk_qr_" + t.TicketId)" href="/Ticket/QR/@t.TicketId">QR</a>
                </td>
            </tr>
        }
    </tbody>
</table>

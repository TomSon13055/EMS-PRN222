@{
    ViewData["Title"] = "Privacy";
    Layout = "_Layout";

    var header = new EventManagement.ViewModels.PageHeaderViewModel
    {
        Title = "Privacy policy",
        Subtitle = "How we handle your data at Event Management System.",
        Eyebrow = "EMS · Legal"
    };
}

@await Html.PartialAsync("_PageHeader", header)

<article class="body-text" style="max-width: 64ch; padding-top: var(--space-4);">
    <p>Event Management System is committed to protecting your privacy. We only collect information needed to provide our services such as account details, event bookings and wallet transactions. We do not sell your data to third parties.</p>
    <p>For questions about your data, please contact the EMS team.</p>
</article>
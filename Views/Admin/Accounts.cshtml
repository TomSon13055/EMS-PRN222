@model EventManagement.ViewModels.AdminAccountsPageViewModel
@{
    ViewData["Title"] = "Accounts";
    Layout = "_Layout";

    var header = new EventManagement.ViewModels.PageHeaderViewModel
    {
        Title = "Accounts",
        Subtitle = "Manage all user accounts on the platform. Lock or unlock access as needed.",
        Eyebrow = "EMS • Admin"
    };
}

@await Html.PartialAsync("_PageHeader", header)

@if (Model.Accounts.Any())
{
    <div class="data-table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Created at</th>
                    <th class="actions">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Accounts)
                {
                    var roleClass = u.Role switch
                    {
                        "Host" => "role-pill role-pill--host",
                        "Customer" => "role-pill role-pill--customer",
                        "Admin" => "role-pill role-pill--admin",
                        _ => "role-pill"
                    };
                    <tr>
                        <td>
                            <div class="table-title">@u.FullName</div>
                            <small class="text-muted">#@u.UserId</small>
                        </td>
                        <td>@u.Email</td>
                        <td><span class="@roleClass">@u.Role</span></td>
                        <td>
                            <span class="status-badge @(u.IsActive ? "status-badge--success" : "status-badge--danger")">
                                @(u.IsActive ? "Active" : "Locked")
                            </span>
                        </td>
                        <td class="text-secondary nowrap">@u.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                        <td class="actions">
                            <form asp-action="ToggleAccount" asp-route-userId="@u.UserId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn @(u.IsActive ? "btn--warning" : "btn--success") btn--sm">
                                    <i class="bi @(u.IsActive ? "bi-lock" : "bi-unlock")" aria-hidden="true"></i>
                                    <span>@(u.IsActive ? "Lock" : "Unlock")</span>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    @await Html.PartialAsync("_EmptyState", new EventManagement.ViewModels.EmptyStateViewModel
    {
        Title = "No accounts",
        Description = "There are no accounts in the system yet.",
        Icon = "bi-people",
        IconVariant = "neutral"
    })
}
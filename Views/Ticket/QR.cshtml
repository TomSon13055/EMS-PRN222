@model EventManagement.ViewModels.TicketQrViewModel
@{
    ViewData["Title"] = "Your Ticket";
    Layout = "_Layout";
}

<div class="vgt-dot-grid" style="background: white; min-height: 100vh; padding: 80px 0;">
    @await Html.PartialAsync("_Navbar")

    <div style="max-width: 640px; margin: 0 auto; padding: 0 40px;">
        <h1 style="font-size: 36px; font-weight: 900; color: #1e1b4b; letter-spacing: -0.02em; text-align: center; margin-bottom: 8px;">
            Your Ticket &#10022;
        </h1>
        <p style="text-align: center; color: #9ca3af; margin-bottom: 40px;">
            Present this QR code at the venue entrance.
        </p>

        <!-- QR Card -->
        <div class="vgt-qr-card">
            <div style="font-weight: 800; font-size: 22px; color: #1e1b4b; margin-bottom: 4px;">
                @Model.EventTitle
            </div>
            <div style="color: #9ca3af; font-size: 14px; margin-bottom: 6px;">
                &#128197; @Model.EventTime.ToString("MMMM dd, yyyy") &#183; @Model.EventTime.ToString("HH:mm")
            </div>
            <div style="color: #6b7280; font-size: 14px; margin-bottom: 32px;">
                &#128205; @Model.Location
            </div>

            <!-- QR Code -->
            <div class="vgt-qr-code">
                <div style="display: grid; grid-template-columns: repeat(8, 1fr); gap: 3px; padding: 16px;">
                    @{
                        var qrDots = new[] { 0, 1, 7, 8, 14, 15, 16, 2, 6, 9, 13, 48, 54, 55, 56, 62, 63, 49, 3, 11, 21, 31, 41, 51, 23, 29, 35, 43, 47, 17, 25, 37 };
                        for (int i = 0; i < 64; i++)
                        {
                            var isBlack = qrDots.Contains(i);
                            <div style="width: 20px; height: 20px; border-radius: 2px; background: @(isBlack ? "#1e1b4b" : "transparent");"></div>
                        }
                    }
                </div>
                <div class="vgt-qr-logo">E</div>
            </div>

            <!-- Ticket Info -->
            <div style="display: flex; gap: 24px; justify-content: center; margin-bottom: 24px;">
                <div style="text-align: center;">
                    <div style="font-size: 11px; color: #9ca3af; font-weight: 600; margin-bottom: 2px; text-transform: uppercase;">Ticket Holder</div>
                    <div style="font-weight: 700; color: #1e1b4b;">@Context.GetFullName()</div>
                </div>
                <div style="width: 1px; background: #e5e7eb;"></div>
                <div style="text-align: center;">
                    <div style="font-size: 11px; color: #9ca3af; font-weight: 600; margin-bottom: 2px; text-transform: uppercase;">Serial</div>
                    <div style="font-weight: 700; color: #1e1b4b;">@Model.SerialNumber</div>
                </div>
                <div style="width: 1px; background: #e5e7eb;"></div>
                <div style="text-align: center;">
                    <div style="font-size: 11px; color: #9ca3af; font-weight: 600; margin-bottom: 2px; text-transform: uppercase;">Ticket ID</div>
                    <div style="font-weight: 700; color: #1e1b4b; font-family: monospace; font-size: 13px;">@Model.TicketId</div>
                </div>
            </div>

            <div style="margin-bottom: 28px;">
                <span class="vgt-badge vgt-badge--active">
                    <span style="width: 6px; height: 6px; border-radius: 50%; background: #10b981; display: inline-block; margin-right: 4px;"></span>
                    Active
                </span>
            </div>

            <div style="display: flex; gap: 12px; justify-content: center;">
                <button class="btn btn--primary" style="border-radius: 12px;">
                    <i class="bi bi-download" aria-hidden="true"></i>
                    Download PDF
                </button>
                <button class="btn btn--vgt-secondary" style="background: rgba(99,102,241,0.08); color: var(--color-indigo); border: 1px solid rgba(99,102,241,0.2); border-radius: 12px;">
                    <i class="bi bi-share" aria-hidden="true"></i>
                    Share
                </button>
            </div>
        </div>

        <!-- Tips -->
        <div class="section-card" style="margin-top: 24px;">
            <div class="section-card__header">
                <div style="font-weight: 700; font-size: 16px; color: #1e1b4b;">
                    &#128161; How to use at venue
                </div>
            </div>
            <div class="section-card__body">
                <div style="display: flex; gap: 12px; margin-bottom: 12px;">
                    <div style="width: 22px; height: 22px; border-radius: 50%; background: var(--vgt-gradient-primary); display: flex; align-items: center; justify-content: center; color: white; font-size: 11px; font-weight: 700; flex-shrink: 0;">1</div>
                    <span style="font-size: 14px; color: #6b7280; line-height: 1.6;">
                        Open this QR code on your phone before arriving at the venue.
                    </span>
                </div>
                <div style="display: flex; gap: 12px; margin-bottom: 12px;">
                    <div style="width: 22px; height: 22px; border-radius: 50%; background: var(--vgt-gradient-primary); display: flex; align-items: center; justify-content: center; color: white; font-size: 11px; font-weight: 700; flex-shrink: 0;">2</div>
                    <span style="font-size: 14px; color: #6b7280; line-height: 1.6;">
                        Present the QR at the check-in counter — staff will scan it instantly.
                    </span>
                </div>
                <div style="display: flex; gap: 12px;">
                    <div style="width: 22px; height: 22px; border-radius: 50%; background: var(--vgt-gradient-primary); display: flex; align-items: center; justify-content: center; color: white; font-size: 11px; font-weight: 700; flex-shrink: 0;">3</div>
                    <span style="font-size: 14px; color: #6b7280; line-height: 1.6;">
                        Your QR code works offline — no internet needed at the venue.
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_Footer")

@section Scripts {
    <script type="module" src="~/js/pages/ticket-qr.js" asp-append-version="true"></script>
}

@model EventManagement.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
}
<h2>Register</h2>
<form asp-action="Register" method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label class="form-label">Full Name</label>
        <input asp-for="FullName" id="txt_fullName" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Email</label>
        <input asp-for="Email" id="txt_email" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Phone</label>
        <input asp-for="Phone" id="txt_phone" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Password</label>
        <input asp-for="Password" id="txt_password" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Confirm Password</label>
        <input asp-for="ConfirmPassword" id="txt_confirmPassword" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Role</label>
        <select asp-for="Role" id="sl_role" class="form-select">
            <option value="Customer">Customer</option>
            <option value="Host">Host</option>
        </select>
    </div>
    <button type="submit" id="btn_register" class="btn btn-primary">Register</button>
    <a asp-action="Login" id="btn_backToLogin" class="btn btn-link">Back to Login</a>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

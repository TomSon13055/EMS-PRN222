@model EventManagement.ViewModels.HostMyEventsPageViewModel
@{
    ViewData["Title"] = "My events";
    Layout = "_Layout";

    var totalTickets = Model.Events.Sum(e => e.TicketSold);
    var totalRevenue = Model.Events.Sum(e => e.Revenue);
    var published = Model.Events.Count(e => string.Equals(e.Status, "Published", StringComparison.OrdinalIgnoreCase));
    var draft = Model.Events.Count(e => string.Equals(e.Status, "Draft", StringComparison.OrdinalIgnoreCase));
}

<header class="page-header">
    <div class="page-header__titles">
        <span class="page-header__eyebrow">Host control room</span>
        <h1 class="page-header__title">Your events, at a glance.</h1>
        <p class="page-header__subtitle">
            Manage your events, track ticket sales and revenue, and create vouchers to promote them.
        </p>
    </div>
    <div class="page-header__actions">
        <a class="btn btn--primary btn--lg" asp-action="CreateEvent">
            <i class="bi bi-plus-lg" aria-hidden="true"></i>
            <span>Create event</span>
        </a>
    </div>
</header>

<section class="host-overview" aria-label="Overview">
    <div class="host-overview__revenue">
        <span class="host-overview__eyebrow">Lifetime revenue</span>
        <span class="host-overview__revenue-value numeric">@totalRevenue.ToString("N0")<span class="host-overview__currency">đ</span></span>
        <span class="host-overview__hint">Across @Model.Events.Count event@(Model.Events.Count == 1 ? "" : "s")</span>
    </div>

    <div class="host-overview__metrics">
        <div class="host-overview__metric">
            <span class="host-overview__metric-label">Tickets sold</span>
            <span class="host-overview__metric-value numeric">@totalTickets</span>
        </div>
        <div class="host-overview__metric">
            <span class="host-overview__metric-label">Published</span>
            <span class="host-overview__metric-value numeric" style="color: var(--success);">@published</span>
        </div>
        <div class="host-overview__metric">
            <span class="host-overview__metric-label">Draft</span>
            <span class="host-overview__metric-value numeric" style="color: var(--warning);">@draft</span>
        </div>
    </div>
</section>

<form method="get" class="host-toolbar" data-host-filter>
    <div class="form-field" style="margin: 0; min-width: 200px;">
        <label class="form-label">Status</label>
        <select name="status" class="form-select" data-host-status>
            @foreach (var s in Model.Statuses)
            {
                <option value="@s.Value" selected="@(string.Equals(Model.Status ?? "", s.Value, StringComparison.OrdinalIgnoreCase))">@s.Text</option>
            }
        </select>
    </div>
    <div class="form-field" style="margin: 0; flex: 1; min-width: 240px;">
        <label class="form-label">Search</label>
        <input type="search" name="search" value="@Model.Search" class="form-control" placeholder="Search by title" />
    </div>
    <button type="submit" class="btn btn--primary">
        <i class="bi bi-funnel" aria-hidden="true"></i>
        <span>Filter</span>
    </button>
</form>

@if (Model.Events.Any())
{
    <div class="data-table-wrap">
        <table class="data-table data-table--compact">
            <thead>
                <tr>
                    <th>Event</th>
                    <th>Category</th>
                    <th>Location</th>
                    <th>Starts</th>
                    <th>Status</th>
                    <th class="numeric">Tickets sold</th>
                    <th class="numeric">Revenue</th>
                    <th class="actions">&nbsp;</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model.Events)
                {
                    var isDraft = string.Equals(e.Status, "Draft", StringComparison.OrdinalIgnoreCase);
                    <tr class="@(isDraft ? "row-draft" : null)">
                        <td>
                            <div class="table-title">@e.Title</div>
                            <small class="text-muted">#@e.EventId</small>
                        </td>
                        <td class="table-sub">@e.Category</td>
                        <td class="table-sub">@e.Location</td>
                        <td class="text-secondary nowrap">@e.StartTime.ToString("dd MMM yyyy HH:mm")</td>
                        <td><partial name="_StatusBadge" model="e.Status" /></td>
                        <td class="numeric">@e.TicketSold</td>
                        <td class="numeric">@e.Revenue.ToString("N0") đ</td>
                        <td class="actions">
                            <div class="action-dropdown" data-action-dropdown aria-expanded="false">
                                <button type="button"
                                        class="icon-btn"
                                        data-action-dropdown-trigger
                                        aria-haspopup="true"
                                        aria-expanded="false"
                                        aria-label="Open actions menu for @e.Title">
                                    <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                                </button>
                                <ul class="action-dropdown__menu" role="menu">
                                    <li>
                                        <a class="action-dropdown__item" role="menuitem"
                                           href="@Url.Action("Edit", "Event", new { id = e.EventId })">
                                            <i class="bi bi-pencil" aria-hidden="true"></i>
                                            <span>Edit event</span>
                                        </a>
                                    </li>
                                    <li>
                                        <a class="action-dropdown__item" role="menuitem"
                                           href="@Url.Action("Create", "TicketType", new { eventId = e.EventId })">
                                            <i class="bi bi-ticket-perforated" aria-hidden="true"></i>
                                            <span>Manage ticket types</span>
                                        </a>
                                    </li>
                                    <li>
                                        <a class="action-dropdown__item" role="menuitem"
                                           href="@Url.Action("Create", "Voucher", new { eventId = e.EventId })">
                                            <i class="bi bi-gift" aria-hidden="true"></i>
                                            <span>Create voucher</span>
                                        </a>
                                    </li>
                                    <li>
                                        <a class="action-dropdown__item" role="menuitem"
                                           href="@Url.Action("Details", "Event", new { id = e.EventId })">
                                            <i class="bi bi-eye" aria-hidden="true"></i>
                                            <span>View public page</span>
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    @await Html.PartialAsync("_EmptyState", new EventManagement.ViewModels.EmptyStateViewModel
    {
        Title = "No events yet",
        Description = "Create your first event to start selling tickets on EMS.",
        Icon = "bi-calendar-plus",
        ActionLabel = "Create your first event",
        ActionUrl = Url.Action("CreateEvent", "Host"),
        ActionIcon = "bi-plus-circle"
    })
}

@section Scripts {
    <script type="module" src="~/js/pages/host-events.js" asp-append-version="true"></script>
    <script type="module" src="~/js/pages/action-dropdown.js" asp-append-version="true"></script>
}
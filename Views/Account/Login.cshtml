@model EventManagement.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}
<h2>Login</h2>
<form asp-action="Login" method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label class="form-label">Email</label>
        <input asp-for="Email" id="txt_email" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Password</label>
        <input asp-for="Password" id="txt_password" class="form-control" />
    </div>
    <button type="submit" id="btn_login" class="btn btn-primary">Login</button>
    <a asp-action="Register" id="lnk_register" class="btn btn-link">Register</a>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

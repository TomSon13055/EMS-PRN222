@model EventManagement.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin dashboard";
    Layout = "_Layout";
}

<header class="page-header page-header--compact">
    <div class="page-header__titles">
        <span class="page-header__eyebrow">Admin control room</span>
        <h1 class="page-header__title">Platform overview.</h1>
        <p class="page-header__subtitle">Snapshot of users, events and ticket sales across EMS.</p>
    </div>
</header>

<section class="host-overview" aria-label="Platform overview">
    <div class="host-overview__revenue">
        <span class="host-overview__eyebrow">Lifetime revenue</span>
        <span class="host-overview__revenue-value numeric">@Model.TotalRevenue.ToString("N0")<span class="host-overview__currency">đ</span></span>
        <span class="host-overview__hint">From @Model.TotalTicketsSold ticket@(Model.TotalTicketsSold == 1 ? "" : "s") sold</span>
    </div>

    <div class="host-overview__metrics">
        <div class="host-overview__metric">
            <span class="host-overview__metric-label">Users</span>
            <span class="host-overview__metric-value numeric">@Model.TotalUsers</span>
        </div>
        <div class="host-overview__metric">
            <span class="host-overview__metric-label">Events</span>
            <span class="host-overview__metric-value numeric">@Model.TotalEvents</span>
        </div>
        <div class="host-overview__metric">
            <span class="host-overview__metric-label">Published</span>
            <span class="host-overview__metric-value numeric" style="color: var(--success);">@Model.TotalPublishedEvents</span>
        </div>
    </div>
</section>

<section class="grid grid--summary" aria-label="Detailed metrics">
    <div class="summary-card">
        <span class="summary-card__label">Total users</span>
        <span class="summary-card__value numeric" id="span_totalUsers">@Model.TotalUsers</span>
        <span class="summary-card__hint">All registered accounts</span>
    </div>
    <div class="summary-card summary-card--accent">
        <span class="summary-card__label">Customers</span>
        <span class="summary-card__value numeric" id="span_totalCustomers">@Model.TotalCustomers</span>
        <span class="summary-card__hint">Attendees on EMS</span>
    </div>
    <div class="summary-card summary-card--warning">
        <span class="summary-card__label">Hosts</span>
        <span class="summary-card__value numeric" id="span_totalHosts">@Model.TotalHosts</span>
        <span class="summary-card__hint">Event organizers</span>
    </div>
    <div class="summary-card">
        <span class="summary-card__label">Tickets sold</span>
        <span class="summary-card__value numeric" id="span_totalTicketsSold">@Model.TotalTicketsSold</span>
        <span class="summary-card__hint">Issued to customers</span>
    </div>
</section>
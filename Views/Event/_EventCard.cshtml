@model EventManagement.ViewModels.EventCardViewModel

@{
    var statusVariant = (Model.Status ?? "").ToLowerInvariant() switch
    {
        "published" => "event-card__badge",
        "draft" => "event-card__badge event-card__badge--accent",
        "ongoing" => "event-card__badge",
        "completed" => "event-card__badge",
        "cancelled" => "event-card__badge event-card__badge--accent",
        _ => "event-card__badge"
    };
    var minPrice = Model.MinPrice;
    var hasPrice = minPrice.HasValue;
    var isFree = hasPrice && minPrice!.Value <= 0;
    var stock = Model.AvailableTickets;

    var startDate = Model.StartTime;
    var dayLabel = startDate.ToString("dd");
    var monthLabel = startDate.ToString("MMM").ToUpperInvariant();

    string stockClass = "event-card__stock";
    string? stockText = null;
    if (stock.HasValue)
    {
        if (stock.Value <= 0) { stockClass += " event-card__stock--low"; stockText = "Sold out"; }
        else if (stock.Value < 10) { stockClass += " event-card__stock--warning"; stockText = $"{stock.Value} tickets left"; }
        else { stockText = $"{stock.Value} tickets left"; }
    }
}

<article class="event-card" data-event-card data-event-id="@Model.EventId">
    <a class="event-card__media-link" href="@Url.Action("Details", "Event", new { id = Model.EventId })"
       aria-label="View @Model.Title" tabindex="-1"></a>

    <div class="event-card__media">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="" loading="lazy" />
        }

        <div class="event-card__date" aria-label="@startDate.ToString("dddd, dd MMMM yyyy")">
            <span class="event-card__date-day">@dayLabel</span>
            <span class="event-card__date-month">@monthLabel</span>
        </div>

        <div class="event-card__badges">
            @if (!string.IsNullOrWhiteSpace(Model.CategoryName))
            {
                <span class="event-card__badge">@Model.CategoryName</span>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Status))
            {
                <span class="@statusVariant">@Model.Status</span>
            }
        </div>

        @if (Model.CanWishlist)
        {
            <form class="event-card__wishlist" method="post"
                  asp-controller="Wishlist" asp-action="Add" asp-route-eventId="@Model.EventId">
                @Html.AntiForgeryToken()
                <button type="submit"
                        class="icon-btn"
                        aria-label="Save @Model.Title to wishlist"
                        title="Save to wishlist">
                    <i class="bi bi-heart" aria-hidden="true"></i>
                </button>
            </form>
        }
    </div>

    <div class="event-card__body">
        <h3 class="event-card__title">
            <a href="@Url.Action("Details", "Event", new { id = Model.EventId })">@Model.Title</a>
        </h3>

        <div class="event-card__meta">
            <div class="event-card__meta-row">
                <i class="bi bi-clock" aria-hidden="true"></i>
                <span>@startDate.ToString("HH:mm") – @Model.EndTime.ToString("HH:mm")</span>
            </div>
            <div class="event-card__meta-row">
                <i class="bi bi-geo-alt" aria-hidden="true"></i>
                <span>@Model.LocationName</span>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.HostName))
            {
                <div class="event-card__meta-row">
                    <i class="bi bi-mic" aria-hidden="true"></i>
                    <span>By @Model.HostName</span>
                </div>
            }
        </div>
    </div>

    <div class="event-card__footer">
        <div class="event-card__price">
            <span class="event-card__price-label">From</span>
            @if (isFree)
            {
                <span class="event-card__price-value event-card__price-free">Free</span>
            }
            else if (hasPrice)
            {
                <span class="event-card__price-value">@minPrice!.Value.ToString("N0")<span style="font-size: 0.7em; margin-left: 2px;">đ</span></span>
            }
            else
            {
                <span class="event-card__price-value" style="color: var(--text-muted);">&mdash;</span>
            }
            @if (stockText != null)
            {
                <span class="@stockClass">@stockText</span>
            }
        </div>
        <div class="action-group">
            @if (Model.CanBuy)
            {
                <a class="btn btn--primary btn--sm"
                   href="@Url.Action("Buy", "Ticket", new { eventId = Model.EventId })">
                    <span>Get ticket</span>
                    <i class="bi bi-arrow-right" aria-hidden="true"></i>
                </a>
            }
            else
            {
                <a class="btn btn--secondary btn--sm"
                   href="@Url.Action("Details", "Event", new { id = Model.EventId })">
                    <span>View</span>
                    <i class="bi bi-arrow-right" aria-hidden="true"></i>
                </a>
            }
            @if (Model.CanEdit)
            {
                <a class="btn btn--ghost btn--sm"
                   href="@Url.Action("Edit", "Event", new { id = Model.EventId })"
                   aria-label="Edit event">
                    <i class="bi bi-pencil" aria-hidden="true"></i>
                </a>
            }
        </div>
    </div>
</article>
@model EventManagement.ViewModels.TicketQrViewModel
@{
    ViewData["Title"] = $"Ticket · {Model.EventTitle}";
    Layout = "_Layout";
}

<nav aria-label="Breadcrumb" class="breadcrumb" style="margin-bottom: var(--space-6);">
    <a href="@Url.Action("MyTickets", "Ticket")">My tickets</a>
    <i class="bi bi-chevron-right breadcrumb__separator" aria-hidden="true"></i>
    <span class="breadcrumb__current">Ticket #@Model.TicketId</span>
</nav>

<div class="ticket-art">
    <div class="ticket-art__stub">
        <div class="ticket-art__stub-top">
            <div class="ticket-art__brand">
                <span class="brand-mark brand-mark--sm">E</span>
                <span>EMS</span>
            </div>
            <span class="ticket-art__stub-label">Admit one</span>
        </div>
        <div class="ticket-art__stub-event">
            <span class="eyebrow" style="color: var(--brand-accent);">Your ticket</span>
            <h1 class="ticket-art__event-title">@Model.EventTitle</h1>
        </div>
        <div class="ticket-art__stub-meta">
            <div>
                <span class="ticket-art__stub-meta-label">When</span>
                <span class="ticket-art__stub-meta-value">@Model.EventTime.ToString("ddd, dd MMM")</span>
                <span class="ticket-art__stub-meta-sub">@Model.EventTime.ToString("HH:mm")</span>
            </div>
            <div>
                <span class="ticket-art__stub-meta-label">Where</span>
                <span class="ticket-art__stub-meta-value">@Model.Location</span>
            </div>
            <div>
                <span class="ticket-art__stub-meta-label">Ticket</span>
                <span class="ticket-art__stub-meta-value mono">#@Model.TicketId</span>
            </div>
        </div>
        <div class="ticket-art__stub-foot">
            <code class="serial">@Model.SerialNumber</code>
            <partial name="_StatusBadge" model="Model.Status" />
        </div>
    </div>

    <div class="ticket-art__perforation" aria-hidden="true"></div>

    <div class="ticket-art__qr">
        <span class="ticket-art__qr-eyebrow">Scan at the door</span>
        <div class="ticket-art__qr-frame">
            <i class="bi bi-grid-3x3-gap-fill ticket-art__qr-placeholder" aria-hidden="true"></i>
            <span class="ticket-art__qr-placeholder-label">QR placeholder</span>
        </div>
        <code class="ticket-art__qr-payload" title="@Model.QrCodeText">@Model.QrCodeText</code>
        <span class="ticket-art__qr-hint">Show this code at the check-in counter.</span>
    </div>
</div>

<div class="ticket-actions">
    <a class="btn btn--outline-secondary" asp-action="MyTickets">
        <i class="bi bi-arrow-left" aria-hidden="true"></i>
        <span>Back to my tickets</span>
    </a>
    <button type="button" class="btn btn--primary" data-print-button>
        <i class="bi bi-printer" aria-hidden="true"></i>
        <span>Print ticket</span>
    </button>
</div>

<p class="ticket-note muted">
    <i class="bi bi-info-circle" aria-hidden="true"></i>
    The QR code is currently shown as a placeholder. A real QR will be generated when a QR library is integrated with the backend.
</p>

@section Scripts {
    <script type="module" src="~/js/pages/ticket-qr.js" asp-append-version="true"></script>
}
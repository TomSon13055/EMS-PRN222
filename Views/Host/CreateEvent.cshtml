@model EventManagement.ViewModels.CreateEventViewModel
@{
    ViewData["Title"] = "Create Event";
    Layout = "_Layout";
}
<h2>Create Event</h2>
<form asp-action="CreateEvent" method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label class="form-label">Title</label>
        <input asp-for="Title" id="txt_title" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea asp-for="Description" id="txt_description" class="form-control" rows="4"></textarea>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Category</label>
            <select asp-for="EventCategoryId" id="sl_category" class="form-select">
                @if (Model.Categories != null)
                {
                    int idx = 0;
                    foreach (var c in Model.Categories.Where(x => !string.IsNullOrEmpty(x.Value)))
                    {
                        idx++;
                        <option id="@("opt_category_" + idx)" value="@c.Value">@c.Text</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Location</label>
            <select asp-for="EventLocationId" id="sl_location" class="form-select">
                @if (Model.Locations != null)
                {
                    int idx = 0;
                    foreach (var l in Model.Locations.Where(x => !string.IsNullOrEmpty(x.Value)))
                    {
                        idx++;
                        <option id="@("opt_location_" + idx)" value="@l.Value">@l.Text</option>
                    }
                }
            </select>
        </div>
    </div>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Start Time</label>
            <input asp-for="StartTime" id="txt_startTime" class="form-control" type="datetime-local" value="@Model.StartTime.ToString("yyyy-MM-ddTHH:mm")" />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">End Time</label>
            <input asp-for="EndTime" id="txt_endTime" class="form-control" type="datetime-local" value="@Model.EndTime.ToString("yyyy-MM-ddTHH:mm")" />
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label">Image URL</label>
        <input asp-for="ImageUrl" id="txt_imageUrl" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Status</label>
        <select asp-for="Status" id="sl_status" class="form-select">
            @if (Model.Statuses != null)
            {
                foreach (var s in Model.Statuses)
                {
                    <option value="@s.Value" selected="@(s.Value == Model.Status)">@s.Text</option>
                }
            }
        </select>
    </div>
    <button id="btn_create" type="submit" class="btn btn-primary">Create</button>
    <a id="btn_back" asp-action="MyEvents" class="btn btn-link">Back</a>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
